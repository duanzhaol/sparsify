{
  "version": "1",
  "meta": {
    "id": "replace-me",
    "name": "Replace Me",
    "version": "0.1.0",
    "extends": "base.taskpack",
    "tags": [
      "research",
      "idea_research"
    ],
    "owner": "team",
    "generated_by": "AutoResearch compiler",
    "source_spec": "task.md"
  },
  "mission": {
    "task_type": "idea_research",
    "objective": "Describe the real task objective here.",
    "success_definition": "Define what counts as a successful round and a successful whole run.",
    "non_goals": [
      "What this task should not optimize for."
    ],
    "hard_constraints": [
      "Non-negotiable rules."
    ],
    "allowed_edit_paths": [
      "workspace/"
    ],
    "deliverables": [
      "Proposal",
      "Evidence summary",
      "Decision and next step"
    ],
    "budget": {
      "max_rounds": 6,
      "budget_hours": 3.0
    }
  },
  "knowledge": {
    "descriptions": [
      {
        "id": "task_source",
        "kind": "file",
        "path": "task.md",
        "roles": [
          "planner",
          "repairer",
          "researcher",
          "reviewer"
        ]
      },
      {
        "id": "task_brief",
        "kind": "file",
        "path": "docs/task_brief.md",
        "roles": [
          "planner",
          "repairer",
          "researcher",
          "reviewer"
        ]
      }
    ],
    "references": [
      {
        "id": "reference_map",
        "kind": "file",
        "path": "docs/reference_map.md",
        "roles": [
          "planner",
          "repairer",
          "researcher",
          "reviewer"
        ]
      }
    ],
    "checklists": [
      {
        "id": "review_checklist",
        "kind": "file",
        "path": "docs/review_checklist.md",
        "roles": [
          "reviewer",
          "repairer"
        ]
      }
    ],
    "prompt_library": {
      "global_system": {
        "kind": "file",
        "path": "prompts/global_system.md"
      },
      "planner_prompt": {
        "kind": "file",
        "path": "prompts/planner.md"
      },
      "reviewer_prompt": {
        "kind": "file",
        "path": "prompts/reviewer.md"
      },
      "researcher_prompt": {
        "kind": "file",
        "path": "prompts/researcher.md"
      },
      "repair_prompt": {
        "kind": "file",
        "path": "prompts/repair.md"
      }
    },
    "skill_library": {
      "domain_context": {
        "kind": "domain_skill",
        "path": "skills/domain_context.md",
        "description": "Task-local domain context."
      },
      "process_playbook": {
        "kind": "process_skill",
        "path": "skills/process_playbook.md",
        "description": "Task-local workflow and record-keeping rules."
      },
      "tooling_guide": {
        "kind": "tool_skill",
        "path": "skills/tooling_guide.md",
        "description": "How runtime tools should be applied in this task pack."
      },
      "review_guardrails": {
        "kind": "safety_skill",
        "path": "skills/review_guardrails.md",
        "description": "Review and escalation rules."
      }
    }
  },
  "field_library": {
    "enums": {
      "change_mode": [
        "analysis_only",
        "writing_change",
        "experiment_change",
        "code_change"
      ],
      "review_verdict": [
        "approve",
        "revise",
        "reject"
      ],
      "decision_label": [
        "keep",
        "discard",
        "rerun",
        "reject"
      ],
      "execution_status": [
        "planned",
        "completed",
        "blocked",
        "failed"
      ]
    },
    "units": {
      "latency_ms": "ms",
      "throughput": "units_per_sec"
    },
    "aliases": {
      "proposal.hypothesis": "The single most important hypothesis or deliverable for the round.",
      "review.verdict": "Structured verdict returned by internal review."
    },
    "records": {
      "proposal": {
        "description": "Plan for one round of work.",
        "fields": {
          "hypothesis": {
            "type": "string",
            "description": "Single core hypothesis for the round.",
            "required": true
          },
          "summary": {
            "type": "string",
            "description": "Short execution summary.",
            "required": true
          },
          "change_mode": {
            "type": "string",
            "enum_ref": "change_mode",
            "description": "What kind of action this round takes."
          }
        }
      },
      "review": {
        "description": "Structured review output.",
        "fields": {
          "verdict": {
            "type": "string",
            "enum_ref": "review_verdict",
            "required": true
          },
          "summary": {
            "type": "string",
            "required": true
          }
        }
      },
      "execution": {
        "description": "Execution summary.",
        "fields": {
          "status": {
            "type": "string",
            "enum_ref": "execution_status",
            "required": true
          },
          "summary": {
            "type": "string",
            "required": true
          }
        }
      }
    }
  },
  "schemas": {
    "proposal": "schemas/proposal.schema.json",
    "review": "schemas/review.schema.json",
    "execution": "schemas/execution.schema.json",
    "evaluation": "schemas/evaluation.schema.json",
    "decision": "schemas/decision.schema.json",
    "report": "schemas/report.schema.json"
  },
  "role_library": {
    "planner": {
      "purpose": "Propose the next high-value step.",
      "prompt_chain": [
        "global_system",
        "planner_prompt"
      ],
      "skills": [
        "domain_context",
        "process_playbook"
      ],
      "allowed_tools": [
        "tool_search"
      ],
      "context_view": "planner_view",
      "input_contract": "state + recent_artifacts + objective_digest",
      "output_schema": "proposal",
      "behavioral_rules": [
        "One core hypothesis per round."
      ]
    },
    "reviewer": {
      "purpose": "Review proposals, patches, or results.",
      "prompt_chain": [
        "global_system",
        "reviewer_prompt"
      ],
      "skills": [
        "review_guardrails",
        "process_playbook"
      ],
      "allowed_tools": [],
      "context_view": "reviewer_view",
      "input_contract": "proposal/result + checklist + prior_reviews",
      "output_schema": "review",
      "behavioral_rules": [
        "Return structured findings only."
      ]
    },
    "researcher": {
      "purpose": "Execute the approved research action and capture evidence.",
      "prompt_chain": [
        "global_system",
        "researcher_prompt"
      ],
      "skills": [
        "domain_context",
        "tooling_guide"
      ],
      "allowed_tools": [
        "tool_task_executor",
        "tool_search"
      ],
      "context_view": "worker_view",
      "input_contract": "accepted proposal + runtime context",
      "output_schema": "execution"
    },
    "repairer": {
      "purpose": "Revise a proposal after review findings.",
      "prompt_chain": [
        "global_system",
        "repair_prompt"
      ],
      "skills": [
        "process_playbook",
        "review_guardrails"
      ],
      "allowed_tools": [],
      "context_view": "repair_view",
      "input_contract": "proposal + findings + constraints",
      "output_schema": "proposal"
    }
  },
  "state_model": {
    "stores": {
      "timeline": {
        "path": "runtime/history/timeline.jsonl",
        "format": "jsonl"
      },
      "memory": {
        "path": "runtime/history/memory.json",
        "format": "json"
      },
      "artifacts": {
        "path": "runtime/history/artifacts",
        "format": "dir"
      },
      "reports": {
        "path": "runtime/history/reports",
        "format": "dir"
      }
    },
    "views": {
      "planner_view": {
        "sections": [
          "objective_digest",
          "recent_rounds",
          "open_hypotheses"
        ]
      },
      "reviewer_view": {
        "sections": [
          "proposal",
          "external_review",
          "prior_reviews",
          "checklists"
        ]
      },
      "worker_view": {
        "sections": [
          "accepted_proposal",
          "allowed_edit_paths",
          "references"
        ]
      },
      "repair_view": {
        "sections": [
          "proposal",
          "external_review",
          "review",
          "constraints"
        ]
      }
    },
    "retention": {
      "recent_rounds_limit": 20
    },
    "compression": {
      "enable_summaries": true
    }
  },
  "objective_model": {
    "optimization_mode": "rubric",
    "metrics": [
      {
        "name": "quality_score",
        "direction": "max"
      }
    ],
    "constraints": [
      "Any hard pass/fail conditions."
    ],
    "rubric": [
      "clarity",
      "novelty",
      "grounding"
    ],
    "decision_policy": {
      "accept_if": "review.verdict == 'approve'"
    },
    "stop_conditions": [
      "No meaningful next step remains."
    ]
  },
  "adapter_registry": {
    "agents": {
      "default_agent": {
        "type": "llm_agent",
        "config": {
          "model": "replace-me"
        }
      }
    },
    "tools": {
      "tool_search": {
        "type": "search"
      },
      "tool_task_executor": {
        "type": "task_executor",
        "config": {
          "mode": "replace-me"
        }
      }
    },
    "evaluators": {
      "default_evaluator": {
        "type": "rubric_evaluator"
      }
    },
    "summarizers": {
      "default_summarizer": {
        "type": "llm_summary"
      }
    },
    "recorders": {
      "default_recorder": {
        "type": "jsonl_recorder"
      }
    },
    "gates": {
      "review_gate": {
        "type": "verdict_gate",
        "config": {
          "accept": [
            "approve"
          ],
          "revise": [
            "revise"
          ],
          "reject": [
            "reject"
          ]
        }
      }
    },
    "reviewers": {
      "external_mcp_review": {
        "type": "mcp_reviewer",
        "config": {
          "server": "replace-me",
          "tool": "replace-me"
        }
      }
    }
  },
  "workflow": {
    "entry_node": "draft_proposal",
    "nodes": {
      "draft_proposal": {
        "kind": "agent",
        "role": "planner",
        "uses": "default_agent",
        "input": {
          "state": "planner_view"
        },
        "output": "proposal"
      },
      "mcp_review": {
        "kind": "mcp_review",
        "uses": "external_mcp_review",
        "input": {
          "proposal": "proposal"
        },
        "output": "external_review"
      },
      "internal_review": {
        "kind": "agent",
        "role": "reviewer",
        "uses": "default_agent",
        "input": {
          "proposal": "proposal",
          "external_review": "external_review",
          "state": "reviewer_view"
        },
        "output": "review"
      },
      "review_gate": {
        "kind": "gate",
        "uses": "review_gate",
        "input": {
          "review": "review"
        },
        "output": "gate_result"
      },
      "repair_plan": {
        "kind": "agent",
        "role": "repairer",
        "uses": "default_agent",
        "input": {
          "proposal": "proposal",
          "review": "review",
          "external_review": "external_review",
          "state": "repair_view"
        },
        "output": "proposal"
      },
      "execute_round": {
        "kind": "tool",
        "uses": "tool_task_executor",
        "input": {
          "proposal": "proposal",
          "state": "worker_view"
        },
        "output": "execution_result"
      },
      "evaluate_result": {
        "kind": "evaluator",
        "uses": "default_evaluator",
        "input": {
          "execution_result": "execution_result",
          "review": "review"
        },
        "output": "evaluation"
      },
      "record_round": {
        "kind": "record",
        "uses": "default_recorder",
        "input": {
          "proposal": "proposal",
          "external_review": "external_review",
          "review": "review",
          "evaluation": "evaluation"
        },
        "output": "recorded_round"
      }
    },
    "edges": [
      {
        "from": "draft_proposal",
        "to": "mcp_review"
      },
      {
        "from": "mcp_review",
        "to": "internal_review"
      },
      {
        "from": "internal_review",
        "to": "review_gate"
      },
      {
        "from": "review_gate",
        "to": "execute_round",
        "when": "gate_result == 'accept'"
      },
      {
        "from": "review_gate",
        "to": "repair_plan",
        "when": "gate_result == 'revise'"
      },
      {
        "from": "review_gate",
        "to": "record_round",
        "when": "gate_result == 'reject'"
      },
      {
        "from": "repair_plan",
        "to": "mcp_review"
      },
      {
        "from": "execute_round",
        "to": "evaluate_result"
      },
      {
        "from": "evaluate_result",
        "to": "record_round"
      }
    ],
    "loop_policies": [
      {
        "name": "review_repair_loop",
        "max_retries": 3
      }
    ],
    "failure_policies": [
      {
        "on": "execution_error",
        "action": "route_to_repair_plan"
      }
    ],
    "stop_conditions": [
      "budget exhausted",
      "objective reached"
    ]
  },
  "reporting": {
    "outputs": [
      "round_summary",
      "final_report"
    ],
    "final_report_schema": "report"
  }
}

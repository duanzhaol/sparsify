{
  "version": "1",
  "meta": {
    "id": "replace-me",
    "name": "Replace Me",
    "version": "0.1.0",
    "extends": "base.taskpack",
    "tags": [
      "research"
    ],
    "owner": "team"
  },
  "mission": {
    "task_type": "idea_research",
    "objective": "Describe the real task objective here.",
    "success_definition": "Define what counts as a successful round and a successful whole run.",
    "non_goals": [
      "What this task should not optimize for."
    ],
    "hard_constraints": [
      "Non-negotiable rules."
    ],
    "allowed_edit_paths": [
      "Optional editable paths."
    ],
    "budget": {
      "max_rounds": 10,
      "budget_hours": 4.0
    }
  },
  "knowledge": {
    "descriptions": [
      {
        "id": "task_brief",
        "kind": "file",
        "path": "taskpacks/replace-me/docs/task_brief.md",
        "roles": [
          "planner",
          "reviewer"
        ]
      }
    ],
    "references": [
      {
        "id": "primary_reference",
        "kind": "file",
        "path": "taskpacks/replace-me/docs/reference.md",
        "roles": [
          "planner",
          "writer",
          "reviewer"
        ]
      }
    ],
    "checklists": [
      {
        "id": "review_checklist",
        "kind": "file",
        "path": "taskpacks/replace-me/docs/review_checklist.md",
        "roles": [
          "reviewer"
        ]
      }
    ],
    "prompt_library": {
      "global_system": {
        "kind": "file",
        "path": "taskpacks/replace-me/prompts/global_system.md"
      },
      "planner_prompt": {
        "kind": "file",
        "path": "taskpacks/replace-me/prompts/planner.md"
      },
      "reviewer_prompt": {
        "kind": "file",
        "path": "taskpacks/replace-me/prompts/reviewer.md"
      },
      "writer_prompt": {
        "kind": "file",
        "path": "taskpacks/replace-me/prompts/writer.md"
      },
      "repair_prompt": {
        "kind": "file",
        "path": "taskpacks/replace-me/prompts/repair.md"
      }
    },
    "skill_library": {
      "domain_skill_a": {
        "kind": "domain_skill",
        "path": "taskpacks/replace-me/skills/domain_skill_a.md",
        "description": "Domain-specific guidance."
      },
      "process_skill_a": {
        "kind": "process_skill",
        "path": "taskpacks/replace-me/skills/process_skill_a.md",
        "description": "Process checklist or workflow guidance."
      },
      "tool_skill_a": {
        "kind": "tool_skill",
        "path": "taskpacks/replace-me/skills/tool_skill_a.md",
        "description": "How to use a tool or benchmark harness."
      },
      "safety_skill_a": {
        "kind": "safety_skill",
        "path": "taskpacks/replace-me/skills/safety_skill_a.md",
        "description": "Safety and review rules."
      }
    }
  },
  "field_library": {
    "enums": {
      "change_mode": [
        "param_only",
        "code_change",
        "data_change",
        "analysis_only"
      ],
      "review_verdict": [
        "approve",
        "revise",
        "reject"
      ],
      "decision_label": [
        "keep",
        "discard",
        "rerun",
        "reject"
      ]
    },
    "units": {
      "latency_ms": "ms",
      "throughput": "samples_per_sec"
    },
    "aliases": {
      "proposal.target": "The primary subject of this round."
    },
    "records": {
      "proposal": {
        "description": "Plan for one round of work.",
        "fields": {
          "hypothesis": {
            "type": "string",
            "description": "Single core hypothesis for the round.",
            "required": true
          },
          "summary": {
            "type": "string",
            "description": "Short execution summary.",
            "required": true
          },
          "change_mode": {
            "type": "string",
            "enum_ref": "change_mode",
            "description": "What kind of action this round takes."
          }
        }
      },
      "review": {
        "description": "Structured review output.",
        "fields": {
          "verdict": {
            "type": "string",
            "enum_ref": "review_verdict",
            "required": true
          },
          "summary": {
            "type": "string",
            "required": true
          }
        }
      }
    }
  },
  "schemas": {
    "proposal": "taskpacks/replace-me/schemas/proposal.schema.json",
    "review": "taskpacks/replace-me/schemas/review.schema.json",
    "execution": "taskpacks/replace-me/schemas/execution.schema.json",
    "evaluation": "taskpacks/replace-me/schemas/evaluation.schema.json",
    "decision": "taskpacks/replace-me/schemas/decision.schema.json",
    "report": "taskpacks/replace-me/schemas/report.schema.json"
  },
  "role_library": {
    "planner": {
      "purpose": "Propose the next high-value step.",
      "prompt_chain": [
        "global_system",
        "planner_prompt"
      ],
      "skills": [
        "domain_skill_a",
        "process_skill_a"
      ],
      "allowed_tools": [
        "tool_search",
        "tool_python_eval"
      ],
      "context_view": "planner_view",
      "input_contract": "state + recent_artifacts + objective_digest",
      "output_schema": "proposal",
      "behavioral_rules": [
        "One core hypothesis per round."
      ]
    },
    "reviewer": {
      "purpose": "Review proposals, patches, or results.",
      "prompt_chain": [
        "global_system",
        "reviewer_prompt"
      ],
      "skills": [
        "safety_skill_a",
        "process_skill_a"
      ],
      "allowed_tools": [
        "tool_review_mcp"
      ],
      "context_view": "reviewer_view",
      "input_contract": "proposal/result + checklist + prior_reviews",
      "output_schema": "review",
      "behavioral_rules": [
        "Return structured findings only."
      ]
    },
    "writer": {
      "purpose": "Generate or revise human-readable artifacts.",
      "prompt_chain": [
        "global_system",
        "writer_prompt"
      ],
      "skills": [
        "domain_skill_a"
      ],
      "allowed_tools": [
        "tool_citation_lookup"
      ],
      "context_view": "writer_view",
      "input_contract": "accepted_results + outline + style_rules",
      "output_schema": "report"
    }
  },
  "state_model": {
    "stores": {
      "timeline": {
        "path": "runtime/history/timeline.jsonl",
        "format": "jsonl"
      },
      "memory": {
        "path": "runtime/history/memory.json",
        "format": "json"
      },
      "artifacts": {
        "path": "runtime/history/artifacts",
        "format": "dir"
      },
      "reports": {
        "path": "runtime/history/reports",
        "format": "dir"
      }
    },
    "views": {
      "planner_view": {
        "sections": [
          "objective_digest",
          "recent_rounds",
          "open_hypotheses"
        ]
      },
      "reviewer_view": {
        "sections": [
          "proposal",
          "artifact_diff",
          "prior_reviews",
          "checklists"
        ]
      },
      "writer_view": {
        "sections": [
          "accepted_results",
          "outline",
          "references"
        ]
      }
    },
    "retention": {
      "recent_rounds_limit": 20
    },
    "compression": {
      "enable_summaries": true
    }
  },
  "objective_model": {
    "optimization_mode": "rubric",
    "metrics": [
      {
        "name": "quality_score",
        "direction": "max"
      }
    ],
    "constraints": [
      "Any hard pass/fail conditions."
    ],
    "rubric": [
      "clarity",
      "novelty",
      "grounding"
    ],
    "decision_policy": {
      "accept_if": "review.verdict == 'approve'"
    },
    "stop_conditions": [
      "No meaningful next step remains."
    ]
  },
  "adapter_registry": {
    "agents": {
      "default_agent": {
        "type": "llm_agent",
        "config": {
          "model": "replace-me"
        }
      }
    },
    "tools": {
      "tool_search": {
        "type": "search"
      },
      "tool_python_eval": {
        "type": "python_function",
        "config": {
          "callable": "module.function"
        }
      },
      "tool_review_mcp": {
        "type": "mcp_tool",
        "config": {
          "server": "replace-me",
          "tool": "replace-me"
        }
      },
      "tool_citation_lookup": {
        "type": "search"
      }
    },
    "evaluators": {
      "default_evaluator": {
        "type": "python_function",
        "config": {
          "callable": "module.evaluate"
        }
      }
    },
    "summarizers": {
      "default_summarizer": {
        "type": "llm_summary"
      }
    },
    "recorders": {
      "default_recorder": {
        "type": "jsonl_recorder"
      }
    },
    "gates": {
      "review_gate": {
        "type": "verdict_gate",
        "config": {
          "accept": [
            "approve"
          ],
          "revise": [
            "revise"
          ],
          "reject": [
            "reject"
          ]
        }
      }
    }
  },
  "workflow": {
    "entry_node": "plan",
    "nodes": {
      "plan": {
        "kind": "agent",
        "role": "planner",
        "uses": "default_agent",
        "input": {
          "state": "planner_view"
        },
        "output": "proposal"
      },
      "proposal_review": {
        "kind": "agent",
        "role": "reviewer",
        "uses": "default_agent",
        "input": {
          "proposal": "proposal",
          "state": "reviewer_view"
        },
        "output": "proposal_review"
      },
      "review_gate": {
        "kind": "gate",
        "uses": "review_gate",
        "input": {
          "review": "proposal_review"
        },
        "output": "gate_result"
      },
      "execute": {
        "kind": "tool",
        "uses": "tool_python_eval",
        "input": {
          "proposal": "proposal"
        },
        "output": "execution_result"
      },
      "evaluate": {
        "kind": "evaluator",
        "uses": "default_evaluator",
        "input": {
          "execution_result": "execution_result"
        },
        "output": "evaluation"
      },
      "record": {
        "kind": "record",
        "uses": "default_recorder",
        "input": {
          "proposal": "proposal",
          "review": "proposal_review",
          "evaluation": "evaluation"
        },
        "output": "recorded_round"
      }
    },
    "edges": [
      {
        "from": "plan",
        "to": "proposal_review"
      },
      {
        "from": "proposal_review",
        "to": "review_gate"
      },
      {
        "from": "review_gate",
        "to": "execute",
        "when": "gate_result == 'accept'"
      },
      {
        "from": "review_gate",
        "to": "plan",
        "when": "gate_result == 'revise'"
      },
      {
        "from": "execute",
        "to": "evaluate"
      },
      {
        "from": "evaluate",
        "to": "record"
      }
    ],
    "loop_policies": [
      {
        "name": "proposal_revision_loop",
        "max_retries": 3
      }
    ],
    "failure_policies": [
      {
        "on": "execution_error",
        "action": "route_to_repair"
      }
    ],
    "stop_conditions": [
      "budget exhausted",
      "objective reached"
    ]
  },
  "reporting": {
    "outputs": [
      "round_summary",
      "final_report"
    ],
    "final_report_schema": "report"
  }
}

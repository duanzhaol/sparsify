{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/autoresearch/taskpack.schema.json",
  "title": "AutoResearch Task Pack",
  "type": "object",
  "required": [
    "version",
    "meta",
    "mission",
    "knowledge",
    "field_library",
    "schemas",
    "role_library",
    "state_model",
    "objective_model",
    "adapter_registry",
    "workflow"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "mission": {
      "$ref": "#/$defs/mission"
    },
    "knowledge": {
      "$ref": "#/$defs/knowledge"
    },
    "field_library": {
      "$ref": "#/$defs/fieldLibrary"
    },
    "schemas": {
      "$ref": "#/$defs/schemaRefs"
    },
    "role_library": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/role"
      }
    },
    "state_model": {
      "$ref": "#/$defs/stateModel"
    },
    "objective_model": {
      "$ref": "#/$defs/objectiveModel"
    },
    "adapter_registry": {
      "$ref": "#/$defs/adapterRegistry"
    },
    "workflow": {
      "$ref": "#/$defs/workflow"
    },
    "reporting": {
      "$ref": "#/$defs/reporting"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "extends": {
          "type": "string"
        },
        "tags": {
          "$ref": "#/$defs/stringArray"
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "mission": {
      "type": "object",
      "required": [
        "task_type",
        "objective",
        "success_definition"
      ],
      "properties": {
        "task_type": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "success_definition": {
          "type": "string"
        },
        "non_goals": {
          "$ref": "#/$defs/stringArray"
        },
        "hard_constraints": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_edit_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "budget": {
          "type": "object",
          "properties": {
            "max_rounds": {
              "type": "integer",
              "minimum": 1
            },
            "budget_hours": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "docRef": {
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "inline",
            "pdf",
            "url",
            "json"
          ]
        },
        "path": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "stages": {
          "$ref": "#/$defs/stringArray"
        },
        "roles": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "promptDef": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "inline",
            "template"
          ]
        },
        "path": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "variables": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "skillDef": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "domain_skill",
            "process_skill",
            "tool_skill",
            "safety_skill",
            "bundle"
          ]
        },
        "path": {
          "type": "string"
        },
        "refs": {
          "$ref": "#/$defs/stringArray"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "descriptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/docRef"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/docRef"
          }
        },
        "checklists": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/docRef"
          }
        },
        "prompt_library": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/promptDef"
          }
        },
        "skill_library": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/skillDef"
          }
        }
      },
      "additionalProperties": true
    },
    "fieldDef": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "enum_ref": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "recordDef": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/fieldDef"
          }
        }
      },
      "additionalProperties": true
    },
    "fieldLibrary": {
      "type": "object",
      "properties": {
        "enums": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/stringArray"
          }
        },
        "units": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "records": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/recordDef"
          }
        }
      },
      "additionalProperties": true
    },
    "schemaRefs": {
      "type": "object",
      "properties": {
        "proposal": {
          "type": "string"
        },
        "review": {
          "type": "string"
        },
        "execution": {
          "type": "string"
        },
        "evaluation": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "report": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "role": {
      "type": "object",
      "required": [
        "purpose",
        "prompt_chain",
        "output_schema"
      ],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "prompt_chain": {
          "$ref": "#/$defs/stringArray"
        },
        "skills": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_tools": {
          "$ref": "#/$defs/stringArray"
        },
        "context_view": {
          "type": "string"
        },
        "input_contract": {
          "type": "string"
        },
        "output_schema": {
          "type": "string"
        },
        "behavioral_rules": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "store": {
      "type": "object",
      "required": [
        "path",
        "format"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "jsonl",
            "tsv",
            "dir",
            "md"
          ]
        }
      },
      "additionalProperties": true
    },
    "stateModel": {
      "type": "object",
      "required": [
        "stores"
      ],
      "properties": {
        "stores": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/store"
          }
        },
        "views": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "retention": {
          "type": "object",
          "additionalProperties": true
        },
        "compression": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "metric": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "min",
            "max"
          ]
        },
        "unit": {
          "type": "string"
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "objectiveModel": {
      "type": "object",
      "required": [
        "optimization_mode"
      ],
      "properties": {
        "optimization_mode": {
          "type": "string",
          "enum": [
            "pareto",
            "scalar",
            "threshold_gate",
            "rubric"
          ]
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        },
        "rubric": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_policy": {
          "type": "object",
          "additionalProperties": true
        },
        "stop_conditions": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "adapter": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "adapterRegistry": {
      "type": "object",
      "properties": {
        "agents": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "evaluators": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "summarizers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "recorders": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "gates": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        },
        "reviewers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/adapter"
          }
        }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "agent",
            "tool",
            "evaluator",
            "gate",
            "mcp_review",
            "router",
            "reducer",
            "record"
          ]
        },
        "role": {
          "type": "string"
        },
        "uses": {
          "type": "string"
        },
        "input": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "output": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "retry_policy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "when": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "required": [
        "entry_node",
        "nodes",
        "edges"
      ],
      "properties": {
        "entry_node": {
          "type": "string"
        },
        "nodes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "loop_policies": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "failure_policies": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "stop_conditions": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "reporting": {
      "type": "object",
      "properties": {
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_report_schema": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}

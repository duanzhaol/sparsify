{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "hypothesis",
    "summary",
    "change_type",
    "experiment_tier",
    "expected_win",
    "family_name",
    "family_stage",
    "self_review",
    "needs_sanity",
    "env_overrides",
    "touched_files",
    "notes_to_memory",
    "next_hypotheses",
    "primary_variable"
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["run"]
    },
    "hypothesis": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "change_type": {
      "type": "string",
      "enum": ["param_only", "edit_sae_code", "edit_perf_code", "no_change"]
    },
    "experiment_tier": {
      "type": "string",
      "enum": ["proxy", "full"]
    },
    "expected_win": {
      "type": "string",
      "enum": ["lower_fvu", "smaller_k", "lower_cost", "explore_unknown"]
    },
    "family_name": {
      "type": "string"
    },
    "family_stage": {
      "type": "string",
      "enum": ["mainline", "prototype", "stabilize", "promote_to_mainline"]
    },
    "self_review": {
      "type": "string"
    },
    "needs_sanity": {
      "type": "boolean"
    },
    "env_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "value"],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "touched_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes_to_memory": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_hypotheses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_variable": {
      "type": "string",
      "enum": ["architecture", "optimizer", "lr", "k", "expansion_factor", "other_param", "code_fix"]
    }
  }
}

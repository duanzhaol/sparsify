from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class

def est(arch, **kw):
    cfg=SparseCoderConfig(architecture=arch, **kw)
    m=_get_sae_class(arch)(1024,cfg,decoder=False)
    e=m.selection_cost_estimate()
    print(arch, kw, 'sel', e['ratio'], 'dep', e['deployment_ratio'], 'total', e['combined_ratio'], 'budget', e['combined_budget_ratio'])

cands=[
 ('topk', dict(expansion_factor=1,k=248)),
 ('factorized_topk', dict(expansion_factor=1,k=128,factorized_hidden_dim=96)),
 ('factorized_topk', dict(expansion_factor=1,k=192,factorized_hidden_dim=96)),
 ('factorized_topk', dict(expansion_factor=1,k=224,factorized_hidden_dim=96)),
 ('factorized_topk', dict(expansion_factor=1,k=128,factorized_hidden_dim=192)),
 ('factorized_topk', dict(expansion_factor=1,k=192,factorized_hidden_dim=192)),
 ('lowrank_factorized_residual', dict(expansion_factor=1,k=48)),
 ('codebook_topk', dict(expansion_factor=1,k=48)),
 ('jumprelu', dict(expansion_factor=1,k=240)),
 ('gated', dict(expansion_factor=1,k=64)),
]
for arch, kw in cands:
    est(arch, **kw)

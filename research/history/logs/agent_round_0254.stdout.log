        original_shape = x.shape[:-1]
        flat_x = x.reshape(-1, self.d_in)
        batch = flat_x.shape[0]

        shared_pre_acts = (
            torch.einsum("bd,sld->bsl", flat_x, self.shared_encoders)
            + self.shared_encoder_bias.unsqueeze(0)

research/history/round_summaries/round_0147.json:25:    "self_review": "\u9075\u5b88\u5355\u53d8\u91cf\u539f\u5219\uff1a\u53ea\u6539 LR\uff0cfamily\u3001EF\u3001K\u3001optimizer \u4e0e\u5bfc\u51fa\u5f62\u5f0f\u5168\u90e8\u56fa\u5b9a\uff0c\u4e0d\u6df7\u5165\u6210\u672c\u8f74\u3001loss \u8f74\u6216\u65b0\u7684\u7ed3\u6784\u53d8\u5316\u3002\u8fd9\u6837\u65e2\u7b26\u5408\u5f53\u524d\u63a8\u8350\u987a\u5e8f\uff0c\u4e5f\u907f\u5f00\u4e86 r146 \u66b4\u9732\u51fa\u7684 clean-baseline \u5305\u88c5\u95ee\u9898\u3002\u98ce\u9669\u662f\u518d\u6b21\u8fd0\u884c 3.3e-3 \u53ef\u80fd\u53ea\u590d\u73b0\u5230\u63a5\u8fd1 3.0e-3 \u7684\u7ed3\u679c\uff0c\u56e0\u6b64\u8bc4\u4f30\u65f6\u5fc5\u987b\u540c\u65f6\u770b\u5b8c\u6574\u66f2\u7ebf\u3001tokens_per_sec\u3001\u603b\u8017\u65f6\u4e0e final_total_tokens\uff0c\u800c\u4e0d\u662f\u53ea\u770b\u6700\u7ec8 FVU\u3002",
research/history/round_summaries/round_0147.json:56:      "\u82e5 LR=3.3e-3 \u518d\u6b21\u4f18\u4e8e 3.0e-3\uff0c\u4e14\u8fd0\u884c\u4ee3\u4ef7\u57fa\u672c\u4e0d\u53d8\uff0c\u5219\u53ef\u628a 3.3e-3 \u89c6\u4e3a\u65b0\u7684 signum \u4e3b\u7ebf\u951a\u70b9\uff0c\u540e\u7eed\u518d\u51b3\u5b9a\u662f\u5426\u7ee7\u7eed\u5fae\u8c03\u6216\u8f6c\u5165 optimizer/\u6210\u672c\u8f74\u3002",
research/history/round_summaries/round_0147.json:79:    "self_review": "\u9075\u5b88\u5355\u53d8\u91cf\u539f\u5219\uff1a\u53ea\u6539 LR\uff0cfamily\u3001EF\u3001K\u3001optimizer \u4e0e\u5bfc\u51fa\u5f62\u5f0f\u5168\u90e8\u56fa\u5b9a\uff0c\u4e0d\u6df7\u5165\u6210\u672c\u8f74\u3001loss \u8f74\u6216\u65b0\u7684\u7ed3\u6784\u53d8\u5316\u3002\u8fd9\u6837\u65e2\u7b26\u5408\u5f53\u524d\u63a8\u8350\u987a\u5e8f\uff0c\u4e5f\u907f\u5f00\u4e86 r146 \u66b4\u9732\u51fa\u7684 clean-baseline \u5305\u88c5\u95ee\u9898\u3002\u98ce\u9669\u662f\u518d\u6b21\u8fd0\u884c 3.3e-3 \u53ef\u80fd\u53ea\u590d\u73b0\u5230\u63a5\u8fd1 3.0e-3 \u7684\u7ed3\u679c\uff0c\u56e0\u6b64\u8bc4\u4f30\u65f6\u5fc5\u987b\u540c\u65f6\u770b\u5b8c\u6574\u66f2\u7ebf\u3001tokens_per_sec\u3001\u603b\u8017\u65f6\u4e0e final_total_tokens\uff0c\u800c\u4e0d\u662f\u53ea\u770b\u6700\u7ec8 FVU\u3002",
research/history/round_summaries/round_0128.json:19:    "hypothesis": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = U(Vx) + \u03a3_m pi_m c_m + \u03a3_i alpha_i^(1) b_i + \u03a3_j alpha_j^(2) b_j\u3002\u5176\u4e2d U(Vx) \u53ef\u5bfc\u51fa\u4e3a\u9759\u6001 trunk \u5411\u91cf\u5e93\uff0c{c_m} \u4e3a\u9759\u6001 soft-codebook \u5e93\uff0c{b_i} \u4e3a\u9759\u6001 residual \u5b57\u5178\u5e93\uff0c\u56e0\u6b64\u6700\u7ec8\u4ecd\u662f\u591a\u4e2a\u9759\u6001\u5411\u91cf\u5e93\u4e0a\u7684\u6709\u9650\u52a0\u6743\u548c\uff0c\u53ef\u843d\u5230 LUTurbo/Lottable \u7684\u2018\u67e5\u8868 + \u52a0\u6743\u6c42\u548c + \u9009\u62e9\u6027\u8865\u507f\u2019\u63a8\u7406\u94fe\u8def\uff0c\u517c\u5bb9\u6027\u4e3a\u6269\u5c55\u517c\u5bb9\u3002r127 \u7684 matched probe \u8bf4\u660e\u4e24\u9636\u6bb5 refinement \u5728 EF=2 \u4e0b\u4ecd\u6709\u771f\u5b9e FVU \u4ef7\u503c\uff0c\u4f46\u5176 selection_cost \u660e\u663e\u9ad8\u4e8e\u5355\u9636\u6bb5\u7236\u8282\u70b9\uff1b\u56e0\u6b64\u672c\u8f6e\u56de\u5230\u4e3b\u7ebf family\uff0c\u53ea\u6539 NUM_CODES=32\uff0c\u6d4b\u8bd5\u662f\u5426\u80fd\u5728\u4fdd\u6301\u4e24\u9636\u6bb5\u7ed3\u6784\u4f18\u52bf\u7684\u540c\u65f6\u538b\u4f4e encoder \u9009\u62e9\u6210\u672c\uff0c\u7f29\u5c0f\u4e0e lowrank_soft_codebook_residual \u7684\u6210\u672c\u5dee\u8ddd\u3002",
research/history/round_summaries/round_0128.json:20:    "summary": "\u56de\u5230 lowrank_two_stage_soft_codebook_residual \u4e3b\u7ebf\uff0c\u56fa\u5b9a K=128\u3001EF=2\u3001signum\u3001LR=3.0e-3\uff0c\u4ec5\u4e0b\u8c03 NUM_CODES \u5230 32\uff0c\u6d4b\u8bd5\u4e24\u9636\u6bb5\u7ed3\u6784\u80fd\u5426\u5728\u4fdd\u7559\u4e3b\u8981 FVU \u4f18\u52bf\u7684\u540c\u65f6\u964d\u4f4e\u9009\u62e9\u6210\u672c\u3002",
research/history/round_summaries/round_0128.json:25:    "self_review": "\u672c\u8f6e\u4e25\u683c\u4fdd\u6301 architecture\u3001K\u3001EF\u3001optimizer\u3001LR \u4e0d\u53d8\uff0c\u53ea\u6539\u4e00\u4e2a\u4f1a\u76f4\u63a5\u5f71\u54cd encoder \u6210\u672c\u7684\u4e3b\u53d8\u91cf\uff0c\u7b26\u5408\u4e3b\u7ebf\u63a8\u8fdb\u548c\u5355\u53d8\u91cf\u539f\u5219\u3002\u98ce\u9669\u5728\u4e8e NUM_CODES=32 \u53ef\u80fd\u8fc7\u4e8e\u6fc0\u8fdb\uff0c\u4f46\u8fd9\u4e00\u6b65\u6700\u76f4\u63a5\u68c0\u9a8c\u4e24\u9636\u6bb5\u4e3b\u7ebf\u662f\u5426\u8fd8\u6709\u5185\u90e8\u964d\u672c\u7a7a\u95f4\u3002",
research/history/round_summaries/round_0128.json:63:      "\u82e5 NUM_CODES=32 \u7ef4\u6301\u63a5\u8fd1\u4e3b\u7ebf FVU \u4e14\u8bad\u7ec3\u66f4\u5feb\uff0c\u5219\u628a\u5b83\u4f5c\u4e3a\u4e24\u9636\u6bb5 family \u7684\u4f4e\u6210\u672c\u53d8\u4f53\u4fdd\u7559\u5728\u517c\u5bb9 frontier \u5019\u9009\u4e2d\u3002"
research/history/round_summaries/round_0128.json:83:    "description": "\u56de\u5230 lowrank_two_stage_soft_codebook_residual \u4e3b\u7ebf\uff0c\u56fa\u5b9a K=128\u3001EF=2\u3001signum\u3001LR=3.0e-3\uff0c\u4ec5\u4e0b\u8c03 NUM_CODES \u5230 32\uff0c\u6d4b\u8bd5\u4e24\u9636\u6bb5\u7ed3\u6784\u80fd\u5426\u5728\u4fdd\u7559\u4e3b\u8981 FVU \u4f18\u52bf\u7684\u540c\u65f6\u964d\u4f4e\u9009\u62e9\u6210\u672c\u3002",
research/history/round_summaries/round_0128.json:84:    "self_review": "\u672c\u8f6e\u4e25\u683c\u4fdd\u6301 architecture\u3001K\u3001EF\u3001optimizer\u3001LR \u4e0d\u53d8\uff0c\u53ea\u6539\u4e00\u4e2a\u4f1a\u76f4\u63a5\u5f71\u54cd encoder \u6210\u672c\u7684\u4e3b\u53d8\u91cf\uff0c\u7b26\u5408\u4e3b\u7ebf\u63a8\u8fdb\u548c\u5355\u53d8\u91cf\u539f\u5219\u3002\u98ce\u9669\u5728\u4e8e NUM_CODES=32 \u53ef\u80fd\u8fc7\u4e8e\u6fc0\u8fdb\uff0c\u4f46\u8fd9\u4e00\u6b65\u6700\u76f4\u63a5\u68c0\u9a8c\u4e24\u9636\u6bb5\u4e3b\u7ebf\u662f\u5426\u8fd8\u6709\u5185\u90e8\u964d\u672c\u7a7a\u95f4\u3002",
research/history/round_summaries/round_0006.json:25:    "self_review": "\u8fd9\u8f6e\u7ee7\u7eed\u6cbf\u5f53\u524d\u6700\u5f3a\u4e3b\u7ebf\u505a\u6700\u5c0f\u5e45\u5ea6\u7684 LR \u5916\u63a8\uff0c\u7b26\u5408\u5355\u53d8\u91cf\u539f\u5219\uff0c\u4e5f\u7b26\u5408\u5148\u5b8c\u6210\u5b66\u4e60\u7387\u626b\u63cf\u518d\u5207 optimizer \u7684\u987a\u5e8f\u3002\u98ce\u9669\u662f\u7ee7\u7eed\u52a0\u5927\u5b66\u4e60\u7387\u53ef\u80fd\u5f15\u5165\u4e0d\u7a33\u5b9a\uff0c\u4f46\u5f53\u524d\u8fde\u7eed\u4e09\u8f6e\u4e0a\u8c03\u90fd\u6539\u5584\u4e86\u7ed3\u679c\uff0c\u56e0\u6b64\u518d\u4e0a\u63a2\u4e00\u6863\u662f\u4fe1\u606f\u6536\u76ca\u6700\u9ad8\u7684\u52a8\u4f5c\uff1b\u82e5\u672c\u8f6e\u4e0d\u518d\u6539\u5584\uff0c\u5c31\u53ef\u4ee5\u8f83\u6709\u628a\u63e1\u5730\u7ed3\u675f signum \u7684 LR \u626b\u63cf\u3002",
research/history/round_summaries/round_0006.json:107:    "self_review": "\u8fd9\u8f6e\u7ee7\u7eed\u6cbf\u5f53\u524d\u6700\u5f3a\u4e3b\u7ebf\u505a\u6700\u5c0f\u5e45\u5ea6\u7684 LR \u5916\u63a8\uff0c\u7b26\u5408\u5355\u53d8\u91cf\u539f\u5219\uff0c\u4e5f\u7b26\u5408\u5148\u5b8c\u6210\u5b66\u4e60\u7387\u626b\u63cf\u518d\u5207 optimizer \u7684\u987a\u5e8f\u3002\u98ce\u9669\u662f\u7ee7\u7eed\u52a0\u5927\u5b66\u4e60\u7387\u53ef\u80fd\u5f15\u5165\u4e0d\u7a33\u5b9a\uff0c\u4f46\u5f53\u524d\u8fde\u7eed\u4e09\u8f6e\u4e0a\u8c03\u90fd\u6539\u5584\u4e86\u7ed3\u679c\uff0c\u56e0\u6b64\u518d\u4e0a\u63a2\u4e00\u6863\u662f\u4fe1\u606f\u6536\u76ca\u6700\u9ad8\u7684\u52a8\u4f5c\uff1b\u82e5\u672c\u8f6e\u4e0d\u518d\u6539\u5584\uff0c\u5c31\u53ef\u4ee5\u8f83\u6709\u628a\u63e1\u5730\u7ed3\u675f signum \u7684 LR \u626b\u63cf\u3002",
research/history/round_summaries/round_0125.json:19:    "hypothesis": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = U(Vx) + \u03a3_m pi_m c_m + \u03a3_i alpha_i^(1) b_i + \u03a3_j alpha_j^(2) b_j\u3002\u5176\u53ef\u5bfc\u51fa\u4e3a\u9759\u6001 trunk \u5411\u91cf\u5e93 U\u3001\u9759\u6001 soft-codebook \u5e93 {c_m} \u4e0e\u9759\u6001 residual \u5b57\u5178\u5e93 {b_i} \u4e0a\u7684\u6709\u9650\u52a0\u6743\u548c\uff0c\u56e0\u6b64\u53ef\u6620\u5c04\u5230 LUTurbo/Lottable \u7684\u2018\u67e5\u8868 + \u52a0\u6743\u6c42\u548c + \u9009\u62e9\u6027\u8865\u507f\u2019\u63a8\u7406\u94fe\u8def\uff0c\u517c\u5bb9\u6027\u4e3a\u6269\u5c55\u517c\u5bb9\u3002\u5f53\u524d family \u5728 EF=2 \u4e0b selection_cost \u7ea6\u4e3a 1.16x \u5230 1.25x\uff0c\u6ee1\u8db3 \u22641.5x \u786c\u7ea6\u675f\u3002r124 \u8868\u660e adam@3.0e-3 \u5728\u8be5\u4e3b\u7ebf\u4e0b\u76f4\u63a5\u7206\u70b8\uff0coptimizer \u8f74\u5df2\u7ed9\u51fa\u660e\u786e\u8d1f\u9762\u4fe1\u53f7\uff0c\u56e0\u6b64\u672c\u8f6e\u53ea\u56de\u7b54\u4e00\u4e2a\u95ee\u9898\uff1a\u5728\u6062\u590d\u7a33\u5b9a\u4e3b\u7ebf signum@3.0e-3 \u540e\uff0cK=96 \u76f8\u5bf9 K=128 \u7684\u66f4\u4f4e\u90e8\u7f72\u67e5\u8868\u6210\u672c\u662f\u5426\u503c\u5f97\u4ee5\u5c11\u91cf FVU \u9000\u5316\u6362\u53d6\u66f4\u597d\u7684\u7cfb\u7edf\u6027\u4ef7\u6bd4\u4e0e\u8bad\u7ec3\u8017\u65f6\u3002",
research/history/round_summaries/round_0125.json:20:    "summary": "\u505c\u6b62\u7ee7\u7eed\u8ffd adam\uff0c\u6062\u590d\u7a33\u5b9a\u4e3b\u7ebf signum\uff0c\u5e76\u6d4b\u8bd5\u66f4\u4f4e deploy \u6210\u672c\u7684 K=96 \u662f\u5426\u5728\u53ef\u63a5\u53d7\u7684 FVU \u635f\u5931\u4e0b\u5e26\u6765\u66f4\u597d\u7684 LUTurbo \u7cfb\u7edf\u6027\u4ef7\u6bd4\u3002",
research/history/round_summaries/round_0125.json:25:    "self_review": "\u672c\u8f6e\u53ea\u6539 K\uff0c\u9075\u5b88\u5355\u53d8\u91cf\u539f\u5219\uff0c\u5e76\u4e14\u5728 optimizer \u8f74\u51fa\u73b0\u660e\u786e\u8d1f\u9762\u4fe1\u53f7\u540e\u8f6c\u5411\u66f4\u8d34\u8fd1 LUTurbo \u603b\u6210\u672c\u76ee\u6807\u7684 deploy \u7ef4\u5ea6\u3002\u7f3a\u70b9\u662f K \u8f74\u4f18\u5148\u7ea7\u4f4e\u4e8e loss/preprocess\uff0c\u4f46\u5f53\u524d\u5df2\u6709\u4e24\u4e2a\u73b0\u6210 frontier \u70b9\u53ef\u76f4\u63a5\u6bd4\u8f83\uff0c\u4fe1\u606f\u56de\u62a5\u66f4\u9ad8\u4e14\u66f4\u63a5\u8fd1\u7cfb\u7edf\u76ee\u6807\u3002",
research/history/round_summaries/round_0125.json:53:      "\u672c\u8f6e\u6539 K \u662f\u56e0\u4e3a signum LR \u8f74\u548c optimizer \u8f74\u90fd\u5df2\u57fa\u672c\u7ed9\u51fa\u4fe1\u53f7\uff0c\u4e14\u5f53\u524d\u7b56\u7565\u660e\u786e\u8981\u6c42\u540c\u65f6\u8003\u8651 deploy \u6210\u672c\u4e0e\u8bad\u7ec3\u8017\u65f6\u3002",
research/history/round_summaries/round_0125.json:57:      "\u82e5 K=96 \u66f2\u7ebf\u4e0e\u6700\u7ec8 FVU \u57fa\u672c\u590d\u73b0 r120\uff0c\u5219\u53ef\u5c06 96 \u4f5c\u4e3a\u4f4e deploy \u6210\u672c\u4fdd\u5b88\u524d\u6cbf\u70b9\u5e76\u6682\u505c\u7ee7\u7eed\u626b K\u3002",
research/history/round_summaries/round_0125.json:79:    "description": "\u505c\u6b62\u7ee7\u7eed\u8ffd adam\uff0c\u6062\u590d\u7a33\u5b9a\u4e3b\u7ebf signum\uff0c\u5e76\u6d4b\u8bd5\u66f4\u4f4e deploy \u6210\u672c\u7684 K=96 \u662f\u5426\u5728\u53ef\u63a5\u53d7\u7684 FVU \u635f\u5931\u4e0b\u5e26\u6765\u66f4\u597d\u7684 LUTurbo \u7cfb\u7edf\u6027\u4ef7\u6bd4\u3002",
research/history/round_summaries/round_0125.json:80:    "self_review": "\u672c\u8f6e\u53ea\u6539 K\uff0c\u9075\u5b88\u5355\u53d8\u91cf\u539f\u5219\uff0c\u5e76\u4e14\u5728 optimizer \u8f74\u51fa\u73b0\u660e\u786e\u8d1f\u9762\u4fe1\u53f7\u540e\u8f6c\u5411\u66f4\u8d34\u8fd1 LUTurbo \u603b\u6210\u672c\u76ee\u6807\u7684 deploy \u7ef4\u5ea6\u3002\u7f3a\u70b9\u662f K \u8f74\u4f18\u5148\u7ea7\u4f4e\u4e8e loss/preprocess\uff0c\u4f46\u5f53\u524d\u5df2\u6709\u4e24\u4e2a\u73b0\u6210 frontier \u70b9\u53ef\u76f4\u63a5\u6bd4\u8f83\uff0c\u4fe1\u606f\u56de\u62a5\u66f4\u9ad8\u4e14\u66f4\u63a5\u8fd1\u7cfb\u7edf\u76ee\u6807\u3002",
research/history/round_summaries/round_0219.json:19:    "hypothesis": "\u5019\u9009 family: factorized_topk\u3002\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = \u03a3_i alpha_i b_i\uff0c\u5176\u4e2d {b_i} \u6765\u81ea\u5355\u4e2a\u9759\u6001\u5411\u91cf\u5e93\uff1b\u4f4e\u79e9 factorized scorer \u53ea\u5f71\u54cd\u5728\u7ebf\u6253\u5206\u4e0e\u9009\u5740\uff0c\u4e0d\u6539\u53d8 decoder \u7aef\u4ecd\u662f\u5355\u5e93\u6709\u9650\u52a0\u6743\u548c\uff0c\u56e0\u6b64\u53ef\u76f4\u63a5\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5355\u5e93\u67e5\u8868 + \u52a0\u6743\u6c42\u548c + \u9009\u62e9\u6027\u8865\u507f\u94fe\u8def\uff0c\u517c\u5bb9\u6027\u4e3a\u76f4\u63a5\u517c\u5bb9\u3002r214-r218 \u5df2\u8868\u660e topk@EF1 \u6cbf K \u8f74\u7ee7\u7eed\u52a0\u9884\u7b97\u4ecd\u80fd\u6539\u5584 FVU\uff0c\u4f46\u6700\u8fd1\u4e24\u8f6e\u6536\u76ca\u5df2\u660e\u663e\u53d8\u5c0f\u4e14\u603b\u8017\u65f6\u4e0a\u5347\u5230 417s\uff0c\u8bf4\u660e\u5355\u7eaf\u5806 topk \u67e5\u8868\u9884\u7b97\u63a5\u8fd1\u8fb9\u9645\u6536\u76ca\u6781\u9650\uff1b\u672c\u8f6e\u56e0\u6b64\u5207\u5230\u66f4\u4f4e encoder \u6210\u672c\u7684 factorized_topk\uff0c\u5e76\u628a K \u63d0\u5230 EF=1 \u4e0b\u7684\u6ee1\u5b57\u5178 256\uff0c\u6d4b\u8bd5\u662f\u5426\u80fd\u5728\u603b\u6210\u672c\u4ecd\u9884\u8ba1\u7ea6 0.44x\u3001\u7ee7\u7eed\u4f4d\u4e8e <0.5x \u533a\u57df\u7684\u524d\u63d0\u4e0b\uff0c\u7528\u66f4\u4fbf\u5b9c\u7684 selector \u6362\u53d6\u66f4\u9ad8\u53ef\u7528 K\uff0c\u4ece\u800c\u62ff\u5230\u63a5\u8fd1\u6216\u4f18\u4e8e topk@0.49x \u7684\u4f4e\u5f00\u9500 FVU\u3002",

/bin/bash -lc "python - <<'PY'
import json
from pathlib import Path
rows=[]
compat=json.loads(Path('research/history/compatibility_registry.json').read_text())
for p in Path('research/history/round_summaries').glob('round_*.json'):
    d=json.loads(p.read_text())
    res=d.get('result',{})
    cfg=d.get('resolved_candidate_env_config') or {}
    arch=cfg.get('ARCHITECTURE') or res.get('architecture')
    if compat.get(arch) not in ('direct_compatible','extended_compatible'):
        continue
    try:
        cost=float(res.get('total_cost_ratio'))
        obj=float(res.get('objective_score'))
        exc=float(res.get('exceed_alpha_0_50'))
        fvu=float(res.get('val_fvu'))
    except (TypeError,ValueError):
        continue
    if 0.18 <= cost <= 0.22:
        rows.append((obj,cost,exc,fvu,int(d['round']),arch,cfg.get('K'),cfg.get('ACTIVE_EXPERTS'),cfg.get('LATENTS_PER_EXPERT'),cfg.get('TRUNK_RANK'),cfg.get('FACTORIZED_HIDDEN_DIM'),res.get('decision')))
for row in sorted(rows)[:80]:
    print(row)

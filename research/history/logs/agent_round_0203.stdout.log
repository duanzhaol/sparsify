from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
cands=[
 ('shared_routed_expert_topk',64,dict(num_experts=64,active_experts=1,latents_per_expert=160,trunk_rank=40,stage1_ratio=0.25,factorized_hidden_dim=256)),
 ('shared_routed_expert_topk',64,dict(num_experts=64,active_experts=1,latents_per_expert=192,trunk_rank=16,stage1_ratio=0.25,factorized_hidden_dim=256)),
 ('shared_lowrank_routed_expert_topk',64,dict(num_experts=64,active_experts=1,latents_per_expert=160,trunk_rank=16,stage1_ratio=0.25,factorized_hidden_dim=256)),
 ('shared_lowrank_routed_expert_topk',64,dict(num_experts=64,active_experts=1,latents_per_expert=192,trunk_rank=16,stage1_ratio=0.25,factorized_hidden_dim=256))
]
for arch,k,extra in cands:
    cfg=SparseCoderConfig(architecture=arch,k=k,expansion_factor=1,**extra)
    cls=_get_sae_class(arch)

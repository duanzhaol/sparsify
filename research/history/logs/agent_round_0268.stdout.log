/bin/bash -lc "python - <<'PY'
import json, glob, os
for p in sorted(glob.glob('research/history/round_summaries/round_*.json')):
    with open(p) as f:
        data=json.load(f)
    rc=data.get('runtime_config_json') or {}
    if rc.get('architecture')=='shared_product_key_expert_jumprelu':
        print(os.path.basename(p), 'round', data['round'], 'stage1_ratio', rc.get('stage1_ratio'), 'obj', data.get('result',{}).get('objective_score'), 'exceed', data.get('result',{}).get('exceed_alpha_0_50'))
PY" in /root/sparsify-ascend

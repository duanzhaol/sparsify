from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import get_sparse_coder_cls

def cost(arch,k,ef=1,trunk_rank=None,num_experts=None,stage1_ratio=None,d_in=1024,n_out=4096):
    cfg = SparseCoderConfig(expansion_factor=ef,k=k,architecture=arch,trunk_rank=trunk_rank,num_experts=num_experts,stage1_ratio=stage1_ratio)
    cls = get_sparse_coder_cls(arch)
    model = cls(d_in,cfg,decoder=False)
    c = model.selection_cost_estimate(n_out)
    print(arch, 'k',k,'ef',ef,'trunk',trunk_rank,'num_experts',num_experts,'stage1',stage1_ratio, c)

for ne in [None,4,8,16,32,64]:
    cost('expert_topk',192,num_experts=ne)
print('---')
for ne in [None,4,8,16,32,64]:
    cost('lowrank_expert_topk',128,trunk_rank=64,num_experts=ne)
print('---')
for ne in [4,8,16,32,64]:
    cost('lowrank_expert_residual',128,trunk_rank=32,stage1_ratio=0.25,num_experts=ne)

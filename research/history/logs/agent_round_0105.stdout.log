                    _wandb.init(
                        entity=os.environ.get("WANDB_ENTITY", None),
                        name=self.full_run_name,
                        project=project_name,
                        config=asdict(self.cfg),
                        save_code=True,
                    )
                    wandb = _wandb
                except Exception:

}
FLOAT_KEYS = {"LR", "AUXK_ALPHA", "STAGE1_RATIO"}
BOOL_KEYS = {"USE_HADAMARD", "COMPILE_MODEL"}

RUNTIME_CONFIG_MAP: dict[str, tuple[str, str]] = {

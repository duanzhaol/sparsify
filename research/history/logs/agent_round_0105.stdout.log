    """Use global top-k selection across all tiles instead of per-tile top-k.
    Only effective when num_tiles > 1."""

    input_mixing: bool = False
    """Apply learnable T×T mixing matrix on tile dimension before encoding.
    Only effective when num_tiles > 1."""

    # Hadamard rotation

/bin/bash -lc "python - <<'PY'
import json
import tempfile
from pathlib import Path

import torch

from research.AutoResearch.override_registry import validate_env_overrides
from research.AutoResearch.runner import _build_env
from research.AutoResearch.state import StateManager
from research.AutoResearch.types import Action, LoopConfig
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig, TrainConfig

rejected = validate_env_overrides(
    [{\"key\": \"LATENTS_PER_EXPERT\", \"value\": \"512\"}],
    fallback_architecture=\"shared_routed_expert_topk\",
)
assert not rejected, rejected

action = Action.from_dict({
    \"command\": \"run\",
    \"change_type\": \"edit_sae_code\",
    \"reference_round\": 104,
    \"family_name\": \"shared_routed_expert_topk\",
    \"family_stage\": \"prototype\",
    \"expected_win\": \"explore_unknown\",
    \"needs_sanity\": True,
    \"hypothesis\": \"validation\",
    \"summary\": \"validation\",
    \"self_review\": \"validation\",
    \"env_overrides\": [{\"key\": \"LATENTS_PER_EXPERT\", \"value\": \"512\"}],
    \"touched_files\": [],
    \"notes_to_memory\": [],
    \"next_hypotheses\": [],
})
state = StateManager()
loop_cfg = LoopConfig()
workdir = Path(tempfile.mkdtemp(prefix=\"latents_per_expert_validate_\"))
_, runtime_cfg = _build_env(
    action,
    \"latents_validate\",
    workdir,
    loop_cfg,
    state,
    target_max_tokens=1,
    resume=False,
)
round_cfg_path = workdir / \"round.config.json\"
round_cfg_path.write_text(json.dumps(runtime_cfg, indent=2) + \"\\n\")
round_cfg = json.loads(round_cfg_path.read_text())
assert round_cfg[\"latents_per_expert\"] == 512, round_cfg
assert round_cfg[\"num_experts\"] == 64, round_cfg

sae_cfg = SparseCoderConfig(
    architecture=\"shared_routed_expert_topk\",
    k=128,
    expansion_factor=1,
    num_experts=64,
    latents_per_expert=512,
)
sae = SparseCoder(1024, sae_cfg, device=\"cpu\", dtype=torch.float32)
x = torch.randn(4, 1024)
out = sae(x)
out.fvu.backward()

train_cfg = TrainConfig(
    sae=sae_cfg,
    batch_size=1,
    grad_acc_steps=8,
    micro_acc_steps=1,
    lr=8e-4,
    auxk_alpha=0.03125,
    dead_feature_threshold=10_000_000,
    hookpoints=[\"layers.[3].self_attn.q_proj\"],
    init_seeds=[0],
    optimizer=\"adam\",
    log_to_wandb=False,
    save_dir=str(workdir),
    run_name=\"latents_validate\",
)
checkpoint_cfg_path = workdir / \"config.json\"
train_cfg.save_json(checkpoint_cfg_path)
checkpoint_cfg = json.loads(checkpoint_cfg_path.read_text())
assert checkpoint_cfg[\"sae\"][\"latents_per_expert\"] == 512, checkpoint_cfg[\"sae\"]
assert checkpoint_cfg[\"sae\"][\"num_experts\"] == 64, checkpoint_cfg[\"sae\"]
print(\"validation_ok\", round_cfg_path, checkpoint_cfg_path)
PY" in /root/sparsify-ascend

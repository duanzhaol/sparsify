/bin/bash -lc "python - <<'PY'
import csv
from collections import defaultdict
path='research/history/results.tsv'
rows=[]
with open(path) as f:
    r=csv.DictReader(f, delimiter='\\t')
    for row in r:
        row['val_fvu']=float(row['val_fvu']) if row.get('val_fvu') else None
        row['k']=int(row['k']) if row.get('k') else None
        row['round_num']=int(row['experiment'].split('_')[0][1:]) if row.get('experiment','').startswith('r') else None
        rows.append(row)
for fam in ['factorized_expert_topk','shared_lowrank_routed_expert_topk','shared_lowrank_two_stage_residual_expert','shared_lowrank_routed_expert_residual','shared_routed_factorized_expert_topk','lowrank_expert_topk']:
    fam_rows=[r for r in rows if r['architecture']==fam and r['val_fvu'] is not None]
    fam_rows.sort(key=lambda r:r['val_fvu'])

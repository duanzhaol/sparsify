+        acts_shape = (*original_shape, self.shared_num_latents)
+        return (
+            top_acts.reshape(target_shape),
+            top_indices.reshape(target_shape),
+            shared_acts.reshape(acts_shape),
+        )
+
+    def _encode_expert_stage(

from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
base = dict(architecture='shared_routed_expert_topk', expansion_factor=1, k=108, active_experts=2, factorized_hidden_dim=256, latents_per_expert=160, num_experts=64, stage1_ratio=0.25, trunk_rank=40)
for k in [111,112,113,114,116]:
    args = base.copy(); args['k']=k
    cfg = SparseCoderConfig(**args)
    m = _get_sae_class(cfg.architecture)(1024, cfg, device='cpu')
    c = m.selection_cost_estimate(n_output=4096)
    print(k, c['ratio'], c['deployment_ratio'], c['combined_ratio'], c['combined_accesses'])

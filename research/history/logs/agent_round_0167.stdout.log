research/history_archive/13_20260326_175854/logs/agent_action_0003.json:1:{"command":"run","hypothesis":"Keeping `lowrank_two_stage_residual` fixed and dropping only `K` from 24 to 16 will test whether this family can extend the Pareto frontier to a smaller-support point without unacceptable FVU degradation.","summary":"Run a parameter-only follow-up on `lowrank_two_stage_residual` at `K=16`, with the rest of the recipe pinned to the current low-K baseline (`EXPANSION_FACTOR=12`, `OPTIMIZER=signum`, `LR=1.6e-3`, `AUXK_ALPHA=0.0`). This directly repairs the prior policy-rejected round by isolating `K` as the sole changed variable.","change_type":"param_only","experiment_tier":"full","expected_win":"smaller_k","family_name":"lowrank_two_stage_residual","family_stage":"stabilize","self_review":"This is the cleanest next probe: it targets the current frontier objective, changes one primary variable, and avoids recipe drift by explicitly pinning the baseline fields.","needs_sanity":false,"env_overrides":[{"key":"ARCHITECTURE","value":"lowrank_two_stage_residual"},{"key":"K","value":"16"},{"key":"EXPANSION_FACTOR","value":"12"},{"key":"OPTIMIZER","value":"signum"},{"key":"LR","value":"1.6e-3"},{"key":"AUXK_ALPHA","value":"0.0"}],"touched_files":[],"notes_to_memory":["Round 4 should be a pure K-isolation run on `lowrank_two_stage_residual`, fixing the prior variable-isolation failure by explicitly pinning architecture, EF, optimizer, LR, and AUXK_ALPHA.","For low-K frontier mapping, treat `K=16` as the next decision point before considering more structural changes."],"next_hypotheses":["If `K=16` stays competitive, continue to `K=8` on the same family to map the low-K tail.","If `K=16` degrades too much, keep `K` in the 16-24 band and test a routed variant for better support allocation.","If `K=16` is close but noisy, keep the family fixed and tune stage allocation instead of changing the broader recipe."],"primary_variable":"k"}

+    def _encoder_linear_layers(self):
+        return [("factor_encoder", self.factor_encoder), ("router", self.router)]
+
+    def _extra_encode_accesses(self) -> list[tuple[str, int, str]]:
+        hidden_dim = self.factor_encoder.out_features

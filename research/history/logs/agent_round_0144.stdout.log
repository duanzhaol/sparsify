+class SharedLowRankTwoStageResidualExpertSparseCoder(SparseCoder):
+    """Shared low-rank coarse stage followed by expert-routed residual cleanup."""
+
+    def __init__(
+        self,
+        d_in: int,
+        cfg: SparseCoderConfig,
+        device: str | torch.device = "cpu",

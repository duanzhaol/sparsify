+            torch.empty(
+                self.num_shared_experts,
+                self.latents_per_expert,
+                hidden_dim,
+                device=device,
+                dtype=dtype,
+            )
+        )
+        self.shared_head_bias = nn.Parameter(
+            torch.zeros(

import json
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
cands = [
 ('lowrank_expert_topk', dict(trunk_rank=16, num_experts=64, active_experts=2, latents_per_expert=160)),
 ('lowrank_factorized_residual', dict(trunk_rank=16, factorized_hidden_dim=256)),
 ('lowrank_gated_residual', dict(trunk_rank=16)),
 ('lowrank_jumprelu_residual', dict(trunk_rank=16)),
 ('whitened_lowrank_residual', dict(trunk_rank=16)),
 ('two_stage_residual_expert', dict(num_experts=64, active_experts=2, latents_per_expert=160, stage1_ratio=0.25)),
]
for arch, extra in cands:
    try:
        cfg = SparseCoderConfig(architecture=arch, k=96, expansion_factor=1, **extra)
        m = _get_sae_class(arch)(1024, cfg, device='cpu')
        c = m.selection_cost_estimate(4096)
        print(arch, json.dumps({'sel': c['ratio'], 'deploy': c['deployment_ratio'], 'total': c['combined_ratio'], 'combined_accesses': c['combined_accesses']}, ensure_ascii=False))
    except Exception as e:
        print(arch, 'ERR', str(e))

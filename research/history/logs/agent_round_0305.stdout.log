for ratio in [0.125,0.25,0.375,0.5]:
    cfg=SparseCoderConfig(
        architecture='shared_cascade_product_key_expert_jumprelu',
        k=32,
        expansion_factor=1,
        num_experts=2048,
        active_experts=2,
        latents_per_expert=56,
        stage1_ratio=ratio,
    )
    sae=SparseCoder(1024,cfg,device='cpu',dtype=None)
    est=sae.selection_cost_estimate(n_output=4096)

/bin/bash -lc "python - <<'PY'
import torch
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import RoutedLowRankTwoStageResidualSparseCoder, LowRankTwoStageResidualSparseCoder

d_in=64
cfg=SparseCoderConfig(k=16, expansion_factor=12, architecture='routed_lowrank_two_stage_residual')
model=RoutedLowRankTwoStageResidualSparseCoder(d_in, cfg, device='cpu', dtype=torch.float32)
x=torch.randn(8,d_in, requires_grad=False)
out=model(x)
loss=out.fvu + 0.01*out.auxk_loss + out.sae_out.pow(2).mean()
loss.backward()
router1 = model.stage1_router.weight.grad
router2 = model.stage2_router.weight.grad
print('router1_grad_nonzero', bool(router1 is not None and router1.abs().sum() > 0))
print('router2_grad_nonzero', bool(router2 is not None and router2.abs().sum() > 0))
base=LowRankTwoStageResidualSparseCoder(d_in, cfg, device='cpu', dtype=torch.float32)
with torch.no_grad():
    routed=model.encode(x)
    plain=base.encode(x)
    same_idx = torch.equal(routed.top_indices, plain.top_indices)
print('same_indices', same_idx)

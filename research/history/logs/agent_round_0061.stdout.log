+    def encode(self, x: Tensor) -> EncoderOutput:
+        x = x - self.b_dec
+        trunk = self.trunk_decoder(self.trunk_encoder(x))
+        residual = x - trunk
+        top_acts, top_indices, pre_acts = self._encode_residual(residual)
+        return EncoderOutput(top_acts, top_indices, pre_acts)

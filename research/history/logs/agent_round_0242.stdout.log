research/history/round_summaries/round_0208.json:23:    "family_name": "topk",
research/history/round_summaries/round_0208.json:25:    "self_review": "\u8be5\u63d0\u6848\u4e25\u683c\u9075\u5b88\u5355\u53d8\u91cf\u539f\u5219\uff0c\u5e76\u76f4\u63a5\u670d\u52a1\u4e8e\u5f53\u524d <0.5x \u533a\u57df\u8865\u70b9\u76ee\u6807\u3002\u4e3b\u8981\u98ce\u9669\u662f EF=1 \u53ef\u80fd\u4f7f topk \u8868\u8fbe\u80fd\u529b\u4e0b\u964d\u8f83\u591a\uff0c\u4f46\u5176\u4fe1\u606f\u4ef7\u503c\u9ad8\uff0c\u56e0\u4e3a\u5b83\u80fd\u76f4\u63a5\u56de\u7b54\u975e factorized \u7b80\u5355\u67b6\u6784\u80fd\u5426\u5728\u771f\u6b63\u4f4e\u6210\u672c\u533a\u7ad9\u4f4f\u811a\u3002",

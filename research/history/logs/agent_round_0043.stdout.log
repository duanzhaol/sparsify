/bin/bash -lc "python - <<'PY'
import json, sys
sys.path.insert(0, '.')
from sparsify.sparse_coder import _get_sae_class
from sparsify.config import SparseCoderConfig

def cost(arch,k=192,ef=1,**extra):
    cfg = SparseCoderConfig(architecture=arch,k=k,expansion_factor=ef,**extra)
    m = _get_sae_class(arch)(1024,cfg,device='cpu')
    return m.selection_cost_estimate(4096)

cases = [
    ('expert_topk', dict()),
    ('lowrank_expert_topk', dict()),
    ('lowrank_expert_topk', dict(trunk_rank=128)),
    ('lowrank_expert_topk', dict(trunk_rank=64)),
    ('lowrank_expert_residual', dict()),
    ('lowrank_expert_residual', dict(trunk_rank=128)),
    ('lowrank_expert_residual', dict(trunk_rank=64)),
    ('lowrank_expert_residual', dict(trunk_rank=128, stage1_ratio=0.25)),
    ('lowrank_expert_residual', dict(trunk_rank=128, stage1_ratio=0.75)),
    ('two_stage_residual_expert', dict()),
    ('two_stage_residual_expert', dict(stage1_ratio=0.25)),
    ('two_stage_residual_expert', dict(stage1_ratio=0.75)),
]
for arch, extra in cases:
    try:
        print(arch, extra)
        print(json.dumps(cost(arch, **extra), ensure_ascii=False))
    except Exception as e:
        print('ERR', arch, extra, e)

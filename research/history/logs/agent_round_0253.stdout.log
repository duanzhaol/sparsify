import math
orig=1024*4096
cands=[('num384',384,96,2),('ae1',512,96,1),('lpe112',512,112,2),('lpe128',512,128,2)]
frontier_controller=0.29352433085441587
frontier_exact=0.290692
for name,ne,lpe,ae in cands:
    left=max(1,math.isqrt(ne)); right=math.ceil(ne/left)
    router=1024*(left+right)
    active=ae*1024*lpe
    sel=router+active
    dep=32*(1024+4096)
    total=sel+dep
    exact=total/orig
    rounded=round(exact,2)
    print(name, {'selection':sel,'total':total,'exact_ratio':exact,'rounded_ratio':rounded,'ctrl_exceed_to_win':frontier_controller-rounded,'exact_exceed_to_win':frontier_exact-exact})

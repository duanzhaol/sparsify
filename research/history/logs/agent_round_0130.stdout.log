    {'active_experts':1,'factorized_hidden_dim':192,'latents_per_expert':320,'k':128},
    {'active_experts':2,'factorized_hidden_dim':256,'latents_per_expert':256,'k':128},
    {'active_experts':1,'factorized_hidden_dim':256,'latents_per_expert':256,'k':128},
    {'active_experts':2,'factorized_hidden_dim':256,'latents_per_expert':320,'k':96},
    {'active_experts':1,'factorized_hidden_dim':256,'latents_per_expert':320,'k':96},
]:
    c=cost(architecture=arch, **params)
    print(params, c)

import sys, json
sys.path.insert(0,'.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig

def cost(**kwargs):
    cfg = SparseCoderConfig(
        architecture=kwargs.pop('architecture'),
        k=kwargs.pop('k',128),
        expansion_factor=kwargs.pop('expansion_factor',1),
        factorized_hidden_dim=kwargs.pop('factorized_hidden_dim',256),
        trunk_rank=kwargs.pop('trunk_rank',40),
        num_experts=kwargs.pop('num_experts',64),
        active_experts=kwargs.pop('active_experts',2),
        latents_per_expert=kwargs.pop('latents_per_expert',320),
        stage1_ratio=kwargs.pop('stage1_ratio',0.25),
    )
    m = SparseCoder(1024, cfg, device='cpu', dtype=None)
    c = m.selection_cost_estimate(n_output=4096)
    return {k:c[k] for k in ['ratio','deployment_ratio','combined_ratio','total_accesses','deployment_accesses','combined_accesses']}

arch='shared_lowrank_routed_expert_topk'
for params in [
    {'active_experts':2,'factorized_hidden_dim':256,'latents_per_expert':320,'k':128},
    {'active_experts':1,'factorized_hidden_dim':256,'latents_per_expert':320,'k':128},

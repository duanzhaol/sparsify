import sys
sys.path.insert(0, '.')
import torch
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig

device = 'cuda' if torch.cuda.is_available() else 'cpu'
try:
    import torch_npu
    if torch.npu.is_available():
        device = 'npu'
except Exception:
    pass

cfg = SparseCoderConfig(
    architecture='shared_lowrank_routed_expert_topk',
    k=128,
    expansion_factor=1,
    factorized_hidden_dim=256,
    num_experts=64,
    active_experts=1,
    latents_per_expert=320,
)
sae = SparseCoder(1024, cfg, device=device, dtype=torch.float32)
x = torch.randn(4, 1024, device=device)
out = sae(x)
out.fvu.backward()
print('integration_smoke: OK', cfg.architecture, cfg.k, cfg.expansion_factor, cfg.active_experts, device)

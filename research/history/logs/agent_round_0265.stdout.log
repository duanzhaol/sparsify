research/history_archive/14_20260326_184609/logs/agent_action_0004.json:1:{"command":"run","hypothesis":"With topk K=128 EF=12 now showing a better anchor at signum LR=1e-3, switching only the optimizer to adam can test whether the remaining gap is optimization-limited rather than learning-rate-limited.","summary":"Keep the topk mainline recipe fixed at K=128 EF=12 LR=1e-3 and run a single-variable optimizer swap from signum to adam.","change_type":"param_only","experiment_tier":"proxy","expected_win":"lower_fvu","family_name":"topk","family_stage":"mainline","self_review":"This follows the prescribed mainline order: after establishing the better LR anchor, the next clean question is optimizer choice. LR, K, and family stay fixed so any curve or FVU change can be attributed to the optimizer.","needs_sanity":false,"env_overrides":[{"key":"ARCHITECTURE","value":"topk"},{"key":"K","value":"128"},{"key":"EXPANSION_FACTOR","value":"12"},{"key":"OPTIMIZER","value":"adam"},{"key":"LR","value":"1e-3"}],"touched_files":[],"notes_to_memory":["Round 4 isolates optimizer choice at the current best topk anchor: K=128, EF=12, LR=1e-3."],"next_hypotheses":["If adam improves the curve or final FVU, keep adam fixed and do one LR callback for adam next.","If adam underperforms signum at the same LR, retain signum as mainline and only revisit optimizer later if curve shape suggests a specific failure mode."],"primary_variable":"optimizer"}

from research.AutoResearch.target_profile import default_target_profile
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
profile = default_target_profile()

cands = [
    ('lowrank_expert_residual',128,1,{'num_experts':32,'trunk_rank':32,'stage1_ratio':0.25}),
    ('lowrank_expert_residual',128,1,{'num_experts':64,'trunk_rank':32,'stage1_ratio':0.25}),
    ('lowrank_expert_residual',128,1,{'num_experts':128,'trunk_rank':32,'stage1_ratio':0.25}),
    ('lowrank_expert_residual',160,1,{'num_experts':64,'trunk_rank':32,'stage1_ratio':0.25}),
    ('two_stage_residual_expert',128,1,{'num_experts':32,'stage1_ratio':0.25}),
    ('two_stage_residual_expert',128,1,{'num_experts':64,'stage1_ratio':0.25}),
    ('two_stage_residual_expert',128,1,{'num_experts':128,'stage1_ratio':0.25}),
    ('lowrank_expert_topk',128,1,{'num_experts':32,'trunk_rank':64,'active_experts':1}),
    ('lowrank_expert_topk',128,1,{'num_experts':32,'trunk_rank':32,'active_experts':1}),
    ('lowrank_expert_topk',128,1,{'num_experts':32,'trunk_rank':48,'active_experts':1}),
]
for arch,k,ef,extra in cands:
    cfg = SparseCoderConfig(architecture=arch, k=k, expansion_factor=ef, **extra)
    cls = _get_sae_class(arch)
    m = cls(profile.d_in, cfg, device='cpu')
    c = m.selection_cost_estimate(profile.n_output)
    print(arch, extra, 'sel', c['ratio'], 'dep', c['deployment_ratio'], 'tot', c['combined_ratio'])

research/history/round_summaries/round_0142.json:20:    "summary": "\u7ee7\u7eed\u6267\u884c\u4e00\u4e2a\u4e25\u683c\u5339\u914d\u7684\u67b6\u6784\u63a2\u9488\uff1a\u628a\u5f53\u524d\u4e3b\u7ebf lowrank_two_stage_soft_codebook_residual \u6362\u6210\u66f4\u7b80\u5316\u7684\u7236\u8282\u70b9 lowrank_residual\uff0c\u5176\u4f59 K=128\u3001EF=2\u3001signum\u3001LR=3.0e-3 \u5168\u90e8\u4fdd\u6301\u4e0d\u53d8\uff0c\u7528\u4e00\u6b21\u5e72\u51c0\u5bf9\u7167\u5224\u65ad soft codebook coarse branch \u5728\u5f53\u524d\u4f4e\u6210\u672c regime \u4e0b\u662f\u5426\u4ecd\u503c\u5f97\u4fdd\u7559\u3002",

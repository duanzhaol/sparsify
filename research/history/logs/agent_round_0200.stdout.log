import json, glob, os
families=['expert_topk','shared_routed_expert_topk','lowrank_expert_topk','shared_two_stage_residual_expert','lowrank_expert_residual','two_stage_residual_expert','shared_routed_factorized_expert_topk','shared_lowrank_two_stage_residual_expert','routed_lowrank_two_stage_residual']
rows=[]
for path in glob.glob('research/history/round_summaries/round_*.json'):
    with open(path) as f:
        d=json.load(f)
    fam=d.get('family_name')
    if fam not in families: continue
    r=d.get('round')
    res=d.get('result',{})
    try:
        obj=float(res.get('objective_score'))
        cost=float(res.get('total_cost_ratio'))
        exc=float(res.get('exceed_alpha_0_50'))
    except:
        continue
    cfg=d.get('resolved_candidate_env_config',{})
    rows.append({
        'round':r,'family':fam,'obj':obj,'cost':cost,'exc':exc,'decision':res.get('decision') or d.get('decision'),
        'K':cfg.get('K'),'ACTIVE_EXPERTS':cfg.get('ACTIVE_EXPERTS'),'LATENTS_PER_EXPERT':cfg.get('LATENTS_PER_EXPERT'),'TRUNK_RANK':cfg.get('TRUNK_RANK'),'FACTORIZED_HIDDEN_DIM':cfg.get('FACTORIZED_HIDDEN_DIM'),'STAGE1_RATIO':cfg.get('STAGE1_RATIO')
    })
for fam in families:
    xs=[x for x in rows if x['family']==fam]
    xs=sorted(xs,key=lambda x:x['obj'])
    print('\\n##',fam)
    for x in xs[:5]:
        print(x)

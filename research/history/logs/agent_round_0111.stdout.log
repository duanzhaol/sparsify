import json
from pathlib import Path
frontier = json.loads(Path('research/history/frontier.json').read_text())
items = frontier.values() if isinstance(frontier, dict) else frontier
rows=[]
for entry in items:
    if not isinstance(entry, dict):
        continue
    cfg = entry.get('config', {}) or {}
    arch = str(entry.get('architecture') or cfg.get('architecture') or cfg.get('family_name') or '').lower()
    if arch not in {'shared_routed_expert_topk','lowrank_expert_topk','lowrank_expert_residual','expert_topk','topk','two_stage_residual_expert'}:
        continue
    rows.append({
        'arch': arch,
        'fvu': entry.get('fvu'),
        'total_ratio': round(float(entry.get('total_cost',0))/4194304,4) if entry.get('total_cost') is not None else None,
        'sel_ratio': round(float(entry.get('selection_cost',0))/4194304,4) if entry.get('selection_cost') is not None else None,
        'deploy_ratio': round(float(entry.get('deployment_accesses',0))/4194304,4) if entry.get('deployment_accesses') is not None else None,
        'k': entry.get('k'),
        'cfg': cfg,
    })
for row in sorted(rows, key=lambda r: (r['total_ratio'], r['fvu'])):
    print(json.dumps(row, ensure_ascii=False))

"},{"key":"K","value":"128"},{"key":"EXPANSION_FACTOR","value":"12"},{"key":"OPTIMIZER","value":"signum"},{"key":"LR","value":"1.6e-3"},{"key":"BATCH_SIZE","value":"1"},{"key":"GRAD_ACC_STEPS","value":"8"},{"key":"MICRO_ACC_STEPS","value":"1"},{"key":"AUXK_ALPHA","value":"0.03125"},{"key":"DEAD_FEATURE_THRESHOLD","value":"10000000"},{"key":"USE_HADAMARD","value":"1"},{"key":"COMPILE_MODEL","value":"1"}],"touched_files":[],"notes_to_memory":["Round 53 showed that on the Hadamard-enabled `gated@128` anchor, raising `LR` to `2.4e-3` does not improve over `LR=2.0e-3`; the curve stayed healthy but the endpoint regressed slightly to `0.143811` versus the `0.142923` anchor.","Round 54 should isolate the remaining LR question on the same strengthened anchor by testing the downward callback to `LR=1.6e-3` at fixed `gated`, `K=128`, `EF=12`, `signum`, and `USE_HADAMARD=1`."],"next_hypotheses":["If `LR=1.6e-3` improves the Hadamard-enabled `gated@128` curve or endpoint, adopt it as the new anchor or run one tight confirmation before revisiting other axes.","If `LR=1.6e-3` is also worse or uniformly slower, close the LR branch and keep `LR=2.0e-3` as the shared mainline recipe before considering any further family-local recipe work."],"primary_variable":"lr"}

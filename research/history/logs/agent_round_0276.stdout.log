import sys
sys.path.insert(0, '.')
import torch
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig

device = 'cuda' if torch.cuda.is_available() else 'cpu'
try:
    import torch_npu
    if torch.npu.is_available():
        device = 'npu'
except ImportError:
    pass

arch = 'dual_shared_adaptive_active_product_key_expert_jumprelu'
cfg = SparseCoderConfig(
    architecture=arch,
    k=32,
    expansion_factor=1,
    stage1_ratio=0.25,
    num_experts=1024,
    active_experts=2,
    latents_per_expert=56,
)
sae = SparseCoder(1024, cfg, device=device, dtype=torch.float32)
x = torch.randn(4, 1024, device=device)
out = sae(x)
out.fvu.backward()
print('integration_smoke: OK', arch, 32, 1, device)

import sys
sys.path.insert(0,'.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
cands = [
    ('shared_routed_factorized_expert_residual', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=160, factorized_hidden_dim=256)),
    ('shared_lowrank_routed_expert_residual', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=160, trunk_rank=16)),
    ('shared_lowrank_routed_expert_topk', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=160, trunk_rank=16)),
    ('shared_routed_factorized_expert_topk', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=160, factorized_hidden_dim=256)),
    ('lowrank_expert_topk', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=224, trunk_rank=16)),
]
for arch, kw in cands:
    try:
        cfg = SparseCoderConfig(architecture=arch, expansion_factor=1, **kw)
        sae = SparseCoder(1024, cfg, device='cpu', dtype=None)
        cost = sae.selection_cost_estimate(4096)
        print(arch, cost['combined_ratio'], cost['total_accesses'], cost['deployment_accesses'])
    except Exception as e:
        print(arch, 'ERR', type(e).__name__, str(e))

def validate_action(
    action: Action,
    state: Any,  # StateManager
) -> tuple[Action | None, str | None]:
    """运行少量硬校验。

    设计原则：
    - 尽量少拦，只拦那些明显会让本轮实验含义不清的情况
    - repair 由 repair loop 处理，不在这里强制改写 action

if [[ "${COMPILE_MODEL}" == "1" ]]; then
  cmd+=(--compile_model)
fi

if [[ "${RESUME}" == "1" ]]; then
  cmd+=(--resume)
fi

if [[ "${PROFILE}" == "1" ]]; then
  mkdir -p "$(dirname "${PROFILE_OUTPUT}")"

    --output "${PROFILE_OUTPUT}" \
    --force-overwrite true \
    --trace cuda,nvtx,osrt,cublas,cudnn \
    --sample none \
    --cpuctxsw none \
    --wait all \
    "${cmd[@]}"
fi

exec "${cmd[@]}"


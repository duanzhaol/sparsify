from sparsify.config import SparseCoderConfig
D=1024; N=4096
common=dict(k=32, expansion_factor=1, num_experts=128, active_experts=2, latents_per_expert=192, factorized_hidden_dim=256, trunk_rank=16, stage1_ratio=0.25)
archs=['expert_jumprelu','adaptive_active_expert_jumprelu','product_key_expert_jumprelu','shared_product_key_expert_jumprelu','hashed_expert_jumprelu','factorized_router_expert_topk','shared_routed_expert_topk','shared_two_stage_residual_expert','factorized_expert_topk','shared_routed_factorized_expert_topk','shared_lowrank_routed_expert_topk','shared_lowrank_two_stage_residual_expert','lowrank_expert_topk','lowrank_expert_jumprelu']
for arch in archs:
    try:
        cfg=SparseCoderConfig(architecture=arch, **common)
        m=_get_sae_class(arch)(D,cfg,device='cpu')
        c=m.selection_cost_estimate(N)
        print(arch, round(c['combined_accesses']/(D*N),6), c['combined_accesses'], c['total_accesses'], c['deployment_accesses'])
    except Exception as e:
        print(arch,'ERROR',e)

    cfg = SparseCoderConfig(architecture='jumprelu', expansion_factor=1, k=k, jumprelu_bandwidth=0.05, jumprelu_init_threshold=0.02)
    m = _get_sae_class('jumprelu')(768, cfg, device='cpu', decoder=False)
    c = m.selection_cost_estimate()
    print(k, c['ratio'], c['deployment_ratio'], c['combined_ratio'])

/bin/bash -lc "python - <<'PY'
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class

def est(arch='shared_routed_expert_topk', **kw):
    args = dict(
        architecture=arch,
        expansion_factor=1,
        k=112,
        active_experts=2,
        factorized_hidden_dim=256,
        latents_per_expert=160,
        num_experts=64,
        stage1_ratio=0.25,
        trunk_rank=40,
    )
    args.update(kw)
    cfg = SparseCoderConfig(**args)
    m = _get_sae_class(cfg.architecture)(1024, cfg, device='cpu')
    c = m.selection_cost_estimate(n_output=4096)
    print(arch, kw if kw else {'baseline': True}, c['ratio'], c['deployment_ratio'], c['combined_ratio'], c['total_accesses'], c['deployment_accesses'])

est()
for ne in [80, 96]:
    est(num_experts=ne)
for k in [104, 120]:
    est(k=k)
for arch in ['shared_routed_factorized_expert_topk', 'shared_lowrank_routed_expert_topk']:
    est(arch=arch)

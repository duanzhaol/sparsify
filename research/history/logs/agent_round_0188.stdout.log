/bin/bash -lc "python - <<'PY'
import sys
sys.path.insert(0,'.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
cands = [
    ('lowrank_residual', dict(k=96, trunk_rank=16)),
    ('routed', dict(k=96)),
    ('bucketed_topk', dict(k=96)),
    ('group_topk', dict(k=96)),
    ('jumprelu', dict(k=96)),
    ('whitened_topk', dict(k=96)),
    ('two_stage_residual_expert', dict(k=96, num_experts=64, active_experts=2, latents_per_expert=160, stage1_ratio=0.25)),
    ('routed_lowrank_two_stage_residual', dict(k=96, trunk_rank=16, num_experts=64, active_experts=2, latents_per_expert=160, stage1_ratio=0.25)),
]
for arch, kw in cands:
    try:
        cfg = SparseCoderConfig(architecture=arch, expansion_factor=1, **kw)
        sae = SparseCoder(1024, cfg, device='cpu', dtype=None)
        cost = sae.selection_cost_estimate(4096)
        print(arch, cost['combined_ratio'], cost['total_accesses'], cost['deployment_accesses'])
    except Exception as e:
        print(arch, 'ERR', type(e).__name__, str(e))

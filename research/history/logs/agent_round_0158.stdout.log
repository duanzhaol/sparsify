import sys
sys.path.insert(0,'.')
import torch
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
arch='lowrank_expert_residual'
cfg=SparseCoderConfig(
    architecture=arch,
    k=96,
    expansion_factor=1,
    trunk_rank=16,
    factorized_hidden_dim=256,
    num_experts=64,
    active_experts=1,
    latents_per_expert=224,
    stage1_ratio=0.25,
)
sae=SparseCoder(1024, cfg, device='cpu', dtype=torch.float32)
x=torch.randn(4,1024)
out=sae(x)
out.fvu.backward()
print('integration_smoke: OK', arch, cfg.k, cfg.expansion_factor, 'cpu', 'fvu=', float(out.fvu.detach()))
print('cost=', sae.selection_cost_estimate(4096))

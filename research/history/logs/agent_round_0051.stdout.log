            torch.empty(
                self.num_experts,
                self.latents_per_expert,
                d_in,
                device=device,
                dtype=dtype,
            )
        )
        self.expert_encoder_bias = nn.Parameter(
            torch.zeros(
                self.num_experts,
                self.latents_per_expert,
                device=device,
                dtype=dtype,
            )


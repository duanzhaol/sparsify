except ImportError:
    device = 'cuda' if torch.cuda.is_available() else 'cpu'

arches = [
    'expert_topk',
    'factorized_expert_topk',
    'lowrank_expert_topk',
    'lowrank_expert_residual',
    'two_stage_residual_expert',
]
for arch in arches:
    cfg = SparseCoderConfig(
        architecture=arch,
        k=32,
        expansion_factor=1,
        num_experts=8,
        active_experts=2,
        trunk_rank=16,
        stage1_ratio=0.5,
        factorized_hidden_dim=64,
    )
    sae = SparseCoder(128, cfg, device=device, dtype=torch.float32)
    x = torch.randn(4, 128, device=device)
    out = sae(x)
    out.fvu.backward()
    print('integration_smoke: OK', arch, device, 'active_experts=', getattr(sae, 'active_experts', None))

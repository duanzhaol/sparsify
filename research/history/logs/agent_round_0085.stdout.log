+def _select_active_expert_indices(
+    router_logits: Tensor,
+    active_experts: int,
+) -> tuple[Tensor, Tensor]:
+    router_probs = torch.softmax(router_logits, dim=-1)
+    active_probs, active_indices = torch.topk(

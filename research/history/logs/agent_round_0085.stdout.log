diff --git a/sparsify/sparse_coder.py b/sparsify/sparse_coder.py
index 577ec2b23685a7c6395c6372de32541018db80d7..be944471cd80e5ed746079fe24322dd09c07c18b
--- a/sparsify/sparse_coder.py

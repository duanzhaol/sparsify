+
+        stage2a_acts, stage2a_indices, stage2a_full = self._encode_ordered_expert_stage(
+            residual,
+            selected_expert_idx,
+            selected_probs,
+            slot=0,
+            topk=self.stage2a_k,
+        )
+        stage2a_out = self._decode_sparse(stage2a_acts, stage2a_indices)

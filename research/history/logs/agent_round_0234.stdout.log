        pre_acts = F.relu(F.linear(hidden, self.encoder.weight, self.encoder.bias))
        top_acts, top_indices = torch.topk(pre_acts, self.cfg.k, dim=-1, sorted=False)
        return top_acts, top_indices, pre_acts


    "routed_lowrank_asymmetric_two_stage_soft_codebook_residual": _SOFT_CODEBOOK_TWOSTAGE_KEYS,
}

STRUCTURAL_OVERRIDE_KEYS = {
    "ARCHITECTURE",
    "K",
    "EXPANSION_FACTOR",
    "NUM_GROUPS",
    "ACTIVE_GROUPS",

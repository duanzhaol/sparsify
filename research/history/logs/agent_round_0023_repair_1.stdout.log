sys.path.insert(0, '.')
import torch
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class

device = 'cuda' if torch.cuda.is_available() else 'cpu'
try:
    import torch_npu
    if torch.npu.is_available():
        device = 'npu'
except ImportError:
    pass

arch = 'expert_topk'
k = 64
ef = 1
cfg = SparseCoderConfig(architecture=arch, k=k, expansion_factor=ef)
sae_cls = _get_sae_class(arch)
sae = sae_cls(1024, cfg, device=device, dtype=torch.float32)
x = torch.randn(4, 1024, device=device)
out = sae(x)
out.fvu.backward()
print('integration_smoke: OK', arch, k, ef, device)
print('selection_cost', sae.selection_cost_estimate(4096))

+        x_centered = x - self.b_dec
+
+        stage1a_acts, stage1a_indices, stage1a_full = self._encode_single_shared_bank(
+            x_centered,
+            bank_idx=0,
+            topk=self.stage1a_k,
+            index_offset=0,
+        )

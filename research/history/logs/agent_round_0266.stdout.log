import sys
sys.path.insert(0, '.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig

architectures = [
    'shared_routed_expert_topk',
    'shared_lowrank_routed_expert_topk',
    'shared_lowrank_two_stage_residual_expert',
    'shared_two_stage_residual_expert',
    'lowrank_expert_topk',
    'lowrank_expert_residual',
    'two_stage_residual_expert',
]
base = dict(
    k=32,
    expansion_factor=1,
    num_experts=1024,
    active_experts=2,
    latents_per_expert=56,
    trunk_rank=16,
    stage1_ratio=0.25,
    factorized_hidden_dim=256,
)
for arch in architectures:
    try:
        cfg = SparseCoderConfig(architecture=arch, **base)
        sae = SparseCoder(1024, cfg, device='cpu', dtype=None)
        est = sae.selection_cost_estimate(4096)
        print(arch, est['combined_ratio'], est['ratio'], est['deployment_ratio'], est['combined_accesses'])
    except Exception as e:
        print(arch, 'ERROR', type(e).__name__, e)

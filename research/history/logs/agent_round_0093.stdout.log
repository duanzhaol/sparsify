/root/sparsify-ascend/research/history/memory.json:710:      "design_hypothesis": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{i\u2208S_{e(x)}(x)} \u03b1_{e,i}(x) b_{e,i} + \u03a3_j \u03b3_j(x) c_j\uff0c\u5176\u4e2d U={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0cC={c_j} \u662f\u9759\u6001 residual \u8865\u507f\u5e93\u3002\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5728\u7ebf\u94fe\u8def\u4ecd\u662f\u201ctrunk \u67e5\u8868 + \u5355 expert \u5b50\u5e93\u67e5\u8868 + residual \u67e5\u8868 + \u6709\u9650\u52a0\u6743\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `lowrank_expert_residual` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\u3002\u517c\u5bb9\u6027\u5148\u7b5b\u6e05\u695a\uff1a`expert_topk` \u76f4\u63a5\u517c\u5bb9\uff1b`lowrank_expert_topk`\u3001`lowrank_expert_residual`\u3001`two_stage_residual_expert` \u5c5e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002r79 \u4e0e r81 \u5df2\u8868\u660e\u7ee7\u7eed\u52a8 `STAGE1_RATIO` \u6216\u7ee7\u7eed\u538b `TRUNK_RANK` \u4f1a\u9000\u5316\uff0cr82 \u53c8\u8868\u660e\u5728 `lowrank_expert_topk` \u4e0a\u628a expert \u7c92\u5ea6\u538b\u7c97\u5230 16 \u4f1a\u660e\u663e\u53d8\u5dee\uff1b\u56e0\u6b64\u5f53\u524d\u6700\u503c\u5f97\u56de\u7b54\u7684\u95ee\u9898\u662f\uff1a\u5728\u4fdd\u7559 residual cleanup \u7684\u4e09\u6bb5\u5f0f\u4e3b\u7ebf\u91cc\uff0c\u66f4\u7c97\u7684 expert \u7c92\u5ea6\u662f\u5426\u4ecd\u7136\u53ef\u884c\u3002\u76f8\u5bf9 r76 \u53ea\u628a `NUM_EXPERTS` \u4ece 64 \u964d\u5230 16\uff0c\u5728\u4fdd\u6301 `ARCHITECTURE=lowrank_expert_residual`\u3001`K=128`\u3001`TRUNK_RANK=32`\u3001`STAGE1_RATIO=0.25`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u4e0e\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\u65f6\uff0c\u76f4\u63a5\u6d4b\u8bd5 residual \u5206\u652f\u662f\u5426\u8db3\u4ee5\u5f25\u8865\u66f4\u7c97 expert \u5212\u5206\u5e26\u6765\u7684\u5c40\u90e8\u5bb9\u91cf\u635f\u5931\uff0c\u5e76\u5728\u51e0\u4e4e\u4e0d\u589e\u90e8\u7f72\u6210\u672c\u7684\u524d\u63d0\u4e0b\u628a selection cost \u518d\u5411\u5de6\u63a8\u4e00\u5c0f\u6bb5\u3002\u5982\u679c `lowrank_expert_topk` \u7684\u7c97 expert \u5931\u8d25\u4e3b\u8981\u56e0\u4e3a\u7f3a\u5c11 residual cleanup\uff0c\u90a3\u4e48\u8fd9\u4e2a\u4e09\u6bb5\u5f0f family \u4ecd\u6709\u673a\u4f1a\u5728\u4f4e\u5230\u4e2d\u6210\u672c\u5e26\u5f62\u6210\u65b0\u7684 Pareto \u6bb5\u3002",
/root/sparsify-ascend/research/history/memory.json:868:        "\u5982\u679c `NUM_EXPERTS=16` \u660e\u663e\u9000\u5316\uff0c\u5219\u53ef\u8f83\u6e05\u695a\u5730\u5224\u65ad\u5f53\u524d target \u4e0a `lowrank_expert_residual` \u7684\u6709\u6548 expert \u7c92\u5ea6\u5df2\u7ecf\u4e0d\u5b9c\u518d\u538b\u7c97\uff0c\u540e\u7eed\u5e94\u628a\u9884\u7b97\u8f6c\u5411\u66f4\u9ad8\u4fe1\u606f\u91cf\u7684\u65b0\u7ed3\u6784\u65b9\u5411\uff0c\u800c\u4e0d\u662f\u7ee7\u7eed\u5728\u73b0\u6709\u7c92\u5ea6\u8f74\u4e0a\u7ec6\u626b\u3002",
/root/sparsify-ascend/research/history/memory.json:874:    "two_stage_residual_expert": {
/root/sparsify-ascend/research/history/memory.json:876:      "design_hypothesis": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = \u03a3_{i\u2208S_1(x)} \u03b1_i(x) b_i + \u03a3_{j\u2208S_{e(r_1)}(r_1)} \u03b3_{e,j}(x) c_{e,j}\uff0c\u5176\u4e2d r_1 = x - \u03a3_{i\u2208S_1(x)} \u03b1_i(x) b_i\uff0cB={b_i} \u662f\u9759\u6001 coarse library\uff0cC_e={c_{e,j}} \u662f\u9759\u6001 expert residual \u5b50\u5e93\uff0ce(r_1) \u662f\u8f7b\u91cf router \u9009\u51fa\u7684\u5355\u4e2a expert\u3002\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5728\u7ebf\u94fe\u8def\u4ecd\u662f\u201ccoarse \u67e5\u8868 + expert residual \u5b50\u5e93\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `two_stage_residual_expert` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\u3002\u517c\u5bb9\u6027\u5148\u7b5b\u6e05\u695a\uff1a`expert_topk` \u76f4\u63a5\u517c\u5bb9\uff1b`lowrank_expert_topk`\u3001`lowrank_expert_residual`\u3001`two_stage_residual_expert`\u3001`factorized_expert_topk` \u5c5e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u5c5e\u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002r77\u3001r78\u3001r79 \u5df2\u8fde\u7eed\u7ed9\u51fa\u6e05\u6670\u8d1f\u4fe1\u53f7\uff1ashared-basis `factorized_expert_topk` \u660e\u663e\u5f31\u4e8e matched `expert_topk`\uff0crouted-only `expert_topk` \u63d0\u9ad8 `K` \u8fdb\u4e00\u6b65\u9000\u5316\uff0c\u800c `lowrank_expert_residual` \u628a `STAGE1_RATIO` \u4ece 0.25 \u63d0\u5230 0.5 \u4e5f\u53d8\u5dee\uff0c\u8bf4\u660e\u5f53\u524d\u4f4e\u5230\u4e2d\u6210\u672c\u5e26\u7684\u4e3b\u8981\u95ee\u9898\u5df2\u4e0d\u592a\u50cf routed-only scorer\u3001lookup budget \u6216 expert-stage \u9884\u7b97\u4e0d\u8db3\u3002\u76f8\u5bf9 r76 \u4ec5\u628a `ARCHITECTURE` \u4ece `lowrank_expert_residual` \u5207\u5230 `two_stage_residual_expert`\uff0c\u4fdd\u6301 `K=128`\u3001`NUM_EXPERTS=64`\u3001`STAGE1_RATIO=0.25`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u548c\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\uff0c\u76f4\u63a5\u56de\u7b54\u5f53\u524d\u9ad8\u4f18\u5148\u7ea7\u7ed3\u6784\u95ee\u9898\uff1a\u5728\u5df2\u7ecf\u7ed9\u8db3 sparse-capacity `NUM_EXPERTS=64` \u7684\u6761\u4ef6\u4e0b\uff0clow-rank trunk \u662f\u5426\u4ecd\u7136\u662f\u5f53\u524d target \u7684\u5fc5\u8981\u7ec4\u6210\uff0c\u8fd8\u662f\u201ccoarse global library + routed expert residual\u201d\u8fd9\u6761 trunk-free staged \u7ed3\u6784\u5df2\u8db3\u591f\u5f62\u6210\u65b0\u7684\u4f4e\u5230\u4e2d\u6210\u672c Pareto \u6bb5\u3002\u5982\u679c\u540e\u8005\u6210\u7acb\uff0c\u8fd9\u4e2a matched architecture probe \u5e94\u5728\u7ea6\u540c\u4e00\u6210\u672c\u5e26\u5185\u63a5\u8fd1 r76\uff1b\u5982\u679c\u4ecd\u660e\u663e\u843d\u540e\uff0c\u5219\u53ef\u66f4\u5e72\u51c0\u5730\u5224\u5b9a\u5f53\u524d target \u4e0a low-rank trunk \u7684\u4ef7\u503c\u5df2\u88ab\u91cd\u65b0\u9a8c\u8bc1\u3002",
/root/sparsify-ascend/research/history/memory.json:929:        "\u5982\u679c `two_stage_residual_expert` \u5728\u8fd1\u540c\u6210\u672c\u4e0b\u63a5\u8fd1\u6216\u4f18\u4e8e r76\uff0c\u5219\u4e0b\u4e00\u8f6e\u4fdd\u6301 family \u4e0d\u53d8\uff0c\u53ea\u6539 `STAGE1_RATIO` \u6216 `K`\uff0c\u5224\u65ad staged sparse \u7ed3\u6784\u662f\u5426\u80fd\u7ee7\u7eed\u5411\u66f4\u4f4e\u6210\u672c\u5e26\u63a8\u8fdb\u3002",
/root/sparsify-ascend/research/history/memory.json:930:        "\u5982\u679c\u5b83\u660e\u663e\u5f31\u4e8e r76\uff0c\u5219\u53ef\u8f83\u6e05\u6670\u5224\u5b9a\u5f53\u524d target \u4e0a low-rank trunk \u4ecd\u662f\u5fc5\u8981\u7ec4\u6210\uff1b\u540e\u7eed\u5e94\u628a\u7ed3\u6784\u9884\u7b97\u6536\u56de\u5230 `lowrank_expert_residual` \u7684 `TRUNK_RANK` \u8f74\uff0c\u800c\u4e0d\u662f\u7ee7\u7eed\u5c55\u5f00 trunk-free staged family\u3002",
/root/sparsify-ascend/research/history/memory.json:931:        "\u5982\u679c\u7ed3\u679c\u5f02\u5e38\uff0c\u5148\u6838\u5bf9 `round*.config.json` \u4e0e checkpoint `config.json` \u4e2d `architecture=two_stage_residual_expert` \u5df2\u771f\u5b9e\u751f\u6548\uff0c\u518d\u51b3\u5b9a\u662f\u5426\u628a\u8be5\u8f6e\u5f53\u4f5c\u7ed3\u6784\u8bc1\u636e\u3002"
/root/sparsify-ascend/research/history/memory.json:936:    "factorized_expert_topk": {
/root/sparsify-ascend/research/history/memory.json:938:      "design_hypothesis": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = \u03a3_{e\u2208E(z(x))} \u03a3_{i\u2208S_e(z(x))} \u03b1_{e,i}(x) b_{e,i}\uff0c\u5176\u4e2d z(x)=Bx \u662f\u5171\u4eab\u4f4e\u7ef4\u6295\u5f71\uff0cE(z) \u662f\u8f7b\u91cf router \u9009\u51fa\u7684\u5c11\u91cf active experts\uff0cexpert \u5185\u7528\u5c0f\u578b low-rank head A_e z \u505a local scoring/top-k\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\u3002\u5728\u7ebf\u4fa7\u53ef\u5bfc\u51fa\u4e3a\u201cshared low-rank projection + \u5c11\u91cf\u9759\u6001 expert \u5b50\u5e93\u9009\u62e9 + \u5b50\u5e93\u5185\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u6c42\u548c\u201d\u7684 LUTurbo/Lottable \u63a8\u7406\u94fe\u8def\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `factorized_expert_topk` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\uff1b`expert_topk` \u5c5e\u4e8e\u76f4\u63a5\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u4ecd\u5c5e\u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002\u552f\u4e00\u4e3b\u5047\u8bbe\uff1a\u76f8\u5bf9 r86 \u4ec5\u628a `ARCHITECTURE` \u4ece `lowrank_expert_topk` \u5207\u5230 `factorized_expert_topk`\uff0c\u5728\u4fdd\u6301 `K=128`\u3001`NUM_EXPERTS=16`\u3001`ACTIVE_EXPERTS=2`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u548c\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\u65f6\uff0c\u5982\u679c r86 \u7684\u5931\u8d25\u4e3b\u8981\u6765\u81ea full-dim routed scorer \u592a\u91cd\u800c\u4e0d\u662f multi-expert MoE-like \u672c\u8eab\uff0c\u90a3\u4e48 shared-basis expert routing \u5e94\u80fd\u5728\u66f4\u4f4e total_cost \u4e0b\u663e\u8457\u6539\u5584 FVU\uff0c\u5e76\u5728\u7ea6 0.3x \u6210\u672c\u5e26\u5f62\u6210\u65b0\u7684\u7ed3\u6784\u6027 anchor\u3002\u6309\u5f53\u524d\u6210\u672c\u6a21\u578b\u7c97\u4f30\uff0cselection\u22480.19x\u3001deployment\u22480.12x\u3001total\u22480.31x\uff0c\u4f4e\u4e8e 1.5\u00d7h\u00d7n \u786c\u7ea6\u675f\u3002",
/root/sparsify-ascend/research/history/memory.json:1031:        "\u5982\u679c `factorized_expert_topk` \u5728\u7ea6 0.31x total_cost \u4e0b\u663e\u8457\u4f18\u4e8e r86 \u5e76\u63a5\u8fd1\u5f53\u524d <0.5x \u524d\u6cbf\uff0c\u5219\u4e0b\u4e00\u8f6e\u4fdd\u6301 family \u4e0d\u53d8\uff0c\u53ea\u6539 `NUM_EXPERTS=32`\uff0c\u9a8c\u8bc1 shared-basis MoE-like \u7684\u5bb9\u91cf\u6269\u5f20\u662f\u5426\u7ee7\u7eed\u6210\u7acb\u3002",
/root/sparsify-ascend/research/history/memory.json:1032:        "\u5982\u679c `factorized_expert_topk` \u6709\u6b63\u4fe1\u53f7\u4f46\u4ecd\u5f31\u4e8e\u9884\u671f\uff0c\u5219\u4e0b\u4e00\u8f6e\u4fdd\u6301 family \u4e0d\u53d8\uff0c\u53ea\u6539 `FACTORIZED_HIDDEN_DIM`\uff0c\u533a\u5206\u74f6\u9888\u662f\u5728 shared basis \u5bbd\u5ea6\u8fd8\u662f\u5728 routed capacity\u3002",
/root/sparsify-ascend/research/history/memory.json:1033:        "\u5982\u679c `factorized_expert_topk` \u4ecd\u7136\u8868\u73b0\u5f88\u5dee\uff0c\u5219\u8bf4\u660e\u5f53\u524d target \u4e0a multi-expert routed-only \u8def\u7ebf\u6574\u4f53\u4e0d\u503c\u5f97\u7ee7\u7eed\uff0c\u540e\u7eed\u5e94\u628a\u4f4e\u6210\u672c\u7ed3\u6784\u9884\u7b97\u8f6c\u56de `lowrank_expert_residual` \u6216 `two_stage_residual_expert`\u3002"

+        # Keep the routed budget fixed but let the second expert see the leftover error.
+        residual_2 = residual - stage2a_out
+        stage2b_acts, stage2b_indices, stage2b_full = self._encode_ordered_expert_stage(
+            residual_2,
+            selected_expert_idx,
+            selected_probs,
+            slot=1,
+            topk=self.stage2b_k,

/bin/bash -lc "python - <<'PY'
import sys
sys.path.insert(0, '.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
base = dict(
    k=32,
    expansion_factor=1,
    num_experts=2048,
    active_experts=2,
    latents_per_expert=56,
    stage1_ratio=0.25,
    factorized_hidden_dim=256,
    trunk_rank=16,
    jumprelu_init_threshold=0.001,
    jumprelu_bandwidth=0.001,
)
archs = [
    'product_key_expert_jumprelu',
    'shared_product_key_expert_jumprelu',
    'shared_lowrank_product_key_expert_jumprelu',
    'dual_shared_lowrank_product_key_expert_jumprelu',
    'lowrank_product_key_expert_jumprelu',
    'product_key_factorized_expert_topk',
    'shared_product_key_factorized_expert_topk',
]
for arch in archs:
    try:
        cfg = SparseCoderConfig(architecture=arch, **base)
        sae = SparseCoder(1024, cfg, device='cpu')
        d = sae.selection_cost_estimate(4096)
        print(arch, d['combined_accesses'], d['combined_ratio'], d['total_accesses'], d['deployment_accesses'])
    except Exception as e:
        print(arch, 'ERR', type(e).__name__, e)
PY" in /root/sparsify-ascend

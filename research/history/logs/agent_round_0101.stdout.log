\u8db3\uff0c\u800c\u4e0d\u53ea\u662f\u603b\u5bb9\u91cf\uff0c\u90a3\u4e48\u5728\u4fdd\u6301\u540c\u4e00\u5bb9\u91cf\u4e0e\u77ed active path \u7684\u524d\u63d0\u4e0b\uff0c\u9002\u5ea6\u589e\u52a0 `K` \u5e94\u80fd\u5728\u4ecd\u4f4e\u4e8e 0.5x total_cost \u7684\u8303\u56f4\u5185\u7ee7\u7eed\u538b\u4f4e FVU\uff0c\u5e76\u5224\u65ad routed-only \u4f4e\u6210\u672c\u7ebf\u6b64\u523b\u66f4\u7f3a\u5bb9\u91cf\u8fd8\u662f\u66f4\u7f3a lookup budget\u3002",
research/history/memory.json:71:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{i\u2208S_{e(x)}(x)} \u03b1_{e,i}(x) b_{e,i} + \u03a3_j \u03b3_j(x) c_j\uff0c\u5176\u4e2d U={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0cC={c_j} \u662f\u9759\u6001 residual \u8865\u507f\u5e93\u3002\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5728\u7ebf\u94fe\u8def\u4ecd\u662f\u201ctrunk \u67e5\u8868 + \u5355 expert \u5b50\u5e93\u67e5\u8868 + residual \u8865\u507f\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `lowrank_expert_residual` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\u3002\u517c\u5bb9\u6027\u5148\u7b5b\u6e05\u695a\uff1a`expert_topk` \u76f4\u63a5\u517c\u5bb9\uff1b`lowrank_expert_topk`\u3001`lowrank_expert_residual`\u3001`two_stage_residual_expert`\u3001`factorized_expert_topk` \u5c5e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u5c5e\u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002r79 \u4e0e r80 \u5df2\u8fde\u7eed\u7ed9\u51fa\u6e05\u6670\u8d1f\u4fe1\u53f7\uff1a\u628a `STAGE1_RATIO` \u4ece 0.25 \u63d0\u5230 0.5 \u4f1a\u53d8\u5dee\uff0c\u800c\u53bb\u6389 low-rank trunk \u7684 `two_stage_residual_expert` \u4e5f\u660e\u663e\u5f31\u4e8e matched `lowrank_expert_residual`\uff0c\u8bf4\u660e\u5f53\u524d\u4f4e\u5230\u4e2d\u6210\u672c\u5e26\u91cc trunk \u4ecd\u662f\u5fc5\u8981\u7ec4\u6210\uff0c\u4e14\u66f4\u5f3a residual cleanup \u6bd4\u66f4\u9ad8 expert-stage \u9884\u7b97\u66f4\u91cd\u8981\u3002\u76f8\u5bf9 r76 \u4ec5\u628a `TRUNK_RANK` \u4ece 32 \u964d\u5230 24\uff0c\u5728\u4fdd\u6301 `ARCHITECTURE=lowrank_expert_residual`\u3001`K=128`\u3001`NUM_EXPERTS=64`\u3001`STAGE1_RATIO=0.25`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u548c\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\u65f6\uff0c\u76f4\u63a5\u56de\u7b54\u5f53\u524d\u6700\u5173\u952e\u7684\u4f4e\u6210\u672c\u95ee\u9898\uff1a\u65e2\u7136 routed-only\u3001shared-basis\u3001stage split\u3001\u4ee5\u53ca trunk-free staged \u8def\u7ebf\u90fd\u672a\u5e26\u6765\u66f4\u4f18\u7ed3\u6784\u6bb5\uff0c\u90a3\u4e48 `lowrank + expert + residual` \u8fd9\u6761\u5f53\u524d\u6700\u5f3a\u517c\u5bb9\u4e3b\u7ebf\u8fd8\u80fd\u5426\u4ec5\u901a\u8fc7\u8fdb\u4e00\u6b65\u538b\u7f29\u5fc5\u8981 trunk \u5bbd\u5ea6\uff0c\u5728\u4fdd\u6301\u5927\u90e8\u5206\u8d28\u91cf\u7684\u540c\u65f6\u628a total_cost \u518d\u5f80\u5de6\u63a8\u4e00\u5c0f\u6bb5\uff0c\u5e76\u5f62\u6210\u6bd4 r76 \u66f4\u7ecf\u6d4e\u7684\u65b0 Pareto \u70b9\u3002",
research/history/memory.json:78:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{i\u2208S_{e(x)}(x)} \u03b1_{e,i}(x) b_{e,i} + \u03a3_j \u03b3_j(x) c_j\uff0c\u5176\u4e2d U={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0cC={c_j} \u662f\u9759\u6001 residual \u8865\u507f\u5e93\u3002\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5728\u7ebf\u94fe\u8def\u4ecd\u662f\u201ctrunk \u67e5\u8868 + \u5355 expert \u5b50\u5e93\u67e5\u8868 + residual \u67e5\u8868 + \u6709\u9650\u52a0\u6743\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `lowrank_expert_residual` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\u3002\u517c\u5bb9\u6027\u5148\u7b5b\u6e05\u695a\uff1a`expert_topk` \u76f4\u63a5\u517c\u5bb9\uff1b`lowrank_expert_topk`\u3001`lowrank_expert_residual`\u3001`two_stage_residual_expert` \u5c5e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002r79 \u4e0e r81 \u5df2\u8868\u660e\u7ee7\u7eed\u52a8 `STAGE1_RATIO` \u6216\u7ee7\u7eed\u538b `TRUNK_RANK` \u4f1a\u9000\u5316\uff0cr82 \u53c8\u8868\u660e\u5728 `lowrank_expert_topk` \u4e0a\u628a expert \u7c92\u5ea6\u538b\u7c97\u5230 16 \u4f1a\u660e\u663e\u53d8\u5dee\uff1b\u56e0\u6b64\u5f53\u524d\u6700\u503c\u5f97\u56de\u7b54\u7684\u95ee\u9898\u662f\uff1a\u5728\u4fdd\u7559 residual cleanup \u7684\u4e09\u6bb5\u5f0f\u4e3b\u7ebf\u91cc\uff0c\u66f4\u7c97\u7684 expert \u7c92\u5ea6\u662f\u5426\u4ecd\u7136\u53ef\u884c\u3002\u76f8\u5bf9 r76 \u53ea\u628a `NUM_EXPERTS` \u4ece 64 \u964d\u5230 16\uff0c\u5728\u4fdd\u6301 `ARCHITECTURE=lowrank_expert_residual`\u3001`K=128`\u3001`TRUNK_RANK=32`\u3001`STAGE1_RATIO=0.25`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u4e0e\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\u65f6\uff0c\u76f4\u63a5\u6d4b\u8bd5 residual \u5206\u652f\u662f\u5426\u8db3\u4ee5\u5f25\u8865\u66f4\u7c97 expert \u5212\u5206\u5e26\u6765\u7684\u5c40\u90e8\u5bb9\u91cf\u635f\u5931\uff0c\u5e76\u5728\u51e0\u4e4e\u4e0d\u589e\u90e8\u7f72\u6210\u672c\u7684\u524d\u63d0\u4e0b\u628a selection cost \u518d\u5411\u5de6\u63a8\u4e00\u5c0f\u6bb5\u3002\u5982\u679c `lowrank_expert_topk` \u7684\u7c97 expert \u5931\u8d25\u4e3b\u8981\u56e0\u4e3a\u7f3a\u5c11 residual cleanup\uff0c\u90a3\u4e48\u8fd9\u4e2a\u4e09\u6bb5\u5f0f family \u4ecd\u6709\u673a\u4f1a\u5728\u4f4e\u5230\u4e2d\u6210\u672c\u5e26\u5f62\u6210\u65b0\u7684 Pareto \u6bb5\u3002",
research/history/memory.json:85:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u8bbe\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{e\u2208E(x-t(x))} \u03a3_{i\u2208S_e(x-t(x))} \u03b1_{e,i}(x) b_{e,i}\uff0c\u5176\u4e2d t(x)=\u03a3_{r=1..R} \u03b2_r(x) u_r\uff0cU={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0cE(x) \u662f\u8f7b\u91cf router \u9009\u51fa\u7684\u5c11\u91cf active experts\uff0c\u4e14 |E(x)| = ACTIVE_EXPERTS \u5f88\u5c0f\u3002\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u5728\u7ebf\u94fe\u8def\u4ecd\u662f\u201ctrunk \u67e5\u8868 + \u5c11\u91cf expert \u5b50\u5e93\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `lowrank_expert_topk` \u4ecd\u5c5e\u6269\u5c55\u517c\u5bb9\u3002\u517c\u5bb9\u6027\u5148\u7b5b\u6e05\u695a\uff1a`expert_topk` \u76f4\u63a5\u517c\u5bb9\uff1b`lowrank_expert_topk`\u3001`lowrank_expert_residual`\u3001`two_stage_residual_expert` \u5c5e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002\u6700\u8fd1 r82 \u4e0e r83 \u5df2\u7ed9\u51fa\u6e05\u6670\u8d1f\u4fe1\u53f7\uff1a\u73b0\u6709\u5355-expert \u8def\u7531\u4e0b\uff0c\u5355\u7eaf\u538b\u7c97 expert \u7c92\u5ea6\u5728 `lowrank_expert_topk` \u4e0e `lowrank_expert_residual` \u90fd\u4f1a\u9000\u5316\u3002\u8fd9\u8bf4\u660e\u5f53\u524d\u771f\u6b63\u672a\u9a8c\u8bc1\u7684\u9ad8\u4f18\u5148\u7ea7\u95ee\u9898\u5df2\u4e0d\u518d\u662f\u65e7\u8f74\u5fae\u8c03\uff0c\u800c\u662f\u63d0\u793a\u91cc\u53cd\u590d\u5f3a\u8c03\u7684\u201c\u603b\u5bb9\u91cf\u4e0e active path \u89e3\u8026\u201d\u662f\u5426\u503c\u5f97\u505a\u6700\u5c0f\u539f\u578b\u3002\u56e0\u6b64\u672c\u8f6e\u4e0d\u518d\u7ee7\u7eed param_only \u7ec6\u626b\uff0c\u800c\u662f\u5bf9 `lowrank_expert_topk` \u589e\u52a0\u65b0 tunable `ACTIVE_EXPERTS`\uff0c\u5e76\u4ee5 r60 \u4e3a\u53c2\u8003\u505a\u7b2c\u4e00\u8f6e\u63a5\u7ebf\u9a8c\u8bc1\uff1a\u53ea\u65b0\u589e env \u53c2\u6570 `ACTIVE_EXPERTS=2`\uff0c\u4fdd\u6301 `K=128`\u3001`TRUNK_RANK=64`\u3001`NUM_EXPERTS=32`\u3001`STAGE1_RATIO=0.25`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u4e0d\u53d8\uff0c\u9a8c\u8bc1 shared trunk + 2-expert routed lookup \u662f\u5426\u80fd\u5728\u603b active path \u4ecd\u77ed\u7684\u524d\u63d0\u4e0b\u6539\u5584\u8d28\u91cf\u3002\u9996\u8f6e\u76ee\u6807\u4e0d\u662f\u5ba3\u79f0\u65b0\u524d\u6cbf\uff0c\u800c\u662f\u5148\u786e\u4fdd `round*.config.json` \u4e0e checkpoint config \u4e2d\u90fd\u771f\u5b9e\u51fa\u73b0 `active_experts=2`\uff0c\u5e76\u62ff\u5230\u7b2c\u4e00\u6761\u517c\u5bb9\u3001\u53ef\u8ba1\u6210\u672c\u3001\u53ef\u5bfc\u51fa\u7684 MoE-like \u8bc1\u636e\u3002",
research/history/memory.json:92:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{e\u2208E(x-t(x))} \u03a3_{i\u2208S_e(x-t(x))} \u03b1_{e,i}(x) b_{e,i}\uff0c\u5176\u4e2d t(x)=\u03a3_r \u03b2_r(x)u_r\uff0cU={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0c|E(x-t(x))|=ACTIVE_EXPERTS=2\u3002\u5728\u7ebf\u5bfc\u51fa\u4ecd\u662f\u201ctrunk \u67e5\u8868 + 2 \u4e2a\u9759\u6001 expert \u5b50\u5e93\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u6c42\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64\u517c\u5bb9\u6027\u5224\u65ad\u4e3a\u6269\u5c55\u517c\u5bb9\u3002\u76f8\u5bf9 r60 \u4ec5\u65b0\u589e ACTIVE_EXPERTS=2\uff0c\u5728\u4fdd\u6301 ARCHITECTURE=lowrank_expert_topk\u3001K=128\u3001TRUNK_RANK=64\u3001NUM_EXPERTS=32\u3001EXPANSION_FACTOR=1\u3001OPTIMIZER=adam\u3001LR=8e-4 \u4e0d\u53d8\u65f6\uff0c\u9a8c\u8bc1 shared trunk + routed experts \u662f\u5426\u80fd\u901a\u8fc7\u66f4\u77ed\u4e8e\u5168\u5bb9\u91cf\u6269\u5f20\u7684 active path \u63d0\u4f9b\u65b0\u7684 0.3x-0.8x total_cost Pareto \u6bb5\u3002\u6309\u5f53\u524d\u6210\u672c\u6a21\u578b\u4f30\u7b97\uff0c\u8be5\u70b9\u7ea6\u4e3a encoder 0.54x\u3001deployment 0.19x\u3001total 0.73x\uff0c\u4f4e\u4e8e 1.5\u00d7h\u00d7n \u786c\u7ea6\u675f\u3002",
research/history/memory.json:99:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = \u03a3_{r=1..R} \u03b2_r(x) u_r + \u03a3_{e\u2208E(x-t(x))} \u03a3_{i\u2208S_e(x-t(x))} \u03b1_{e,i}(x) b_{e,i}\uff0c\u5176\u4e2d t(x)=\u03a3_r \u03b2_r(x)u_r\uff0cU={u_r} \u662f\u9759\u6001 low-rank trunk \u5411\u91cf\u5e93\uff0c{B_e} \u662f\u9759\u6001 expert \u5b50\u5e93\uff0c|E(x-t(x))|=ACTIVE_EXPERTS\u3002\u5728\u7ebf\u5bfc\u51fa\u4ecd\u662f\u201ctrunk \u67e5\u8868 + \u5c11\u91cf\u9759\u6001 expert \u5b50\u5e93\u67e5\u8868 + \u6709\u9650\u52a0\u6743\u6c42\u548c\u201d\uff0c\u9759\u6001\u5e93\u4e0d\u968f\u6837\u672c\u52a8\u6001\u751f\u6210\uff0c\u56e0\u6b64 `lowrank_expert_topk` \u5c5e\u4e8e\u6269\u5c55\u517c\u5bb9\uff1b`batch_topk`\u3001`adaptive_budget_topk` \u7b49 batch/sample-coupled family \u4ecd\u5c5e\u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002\u76f8\u5bf9 r82 \u4ec5\u65b0\u589e `ACTIVE_EXPERTS=2`\uff0c\u5728\u4fdd\u6301 `ARCHITECTURE=lowrank_expert_topk`\u3001`K=128`\u3001`TRUNK_RANK=64`\u3001`NUM_EXPERTS=16`\u3001`EXPANSION_FACTOR=1`\u3001`OPTIMIZER=adam`\u3001`LR=8e-4` \u53ca\u5176\u4f59\u8bad\u7ec3\u914d\u65b9\u4e0d\u53d8\u65f6\uff0c\u5148\u9a8c\u8bc1\u6700\u8fd1\u4fee\u590d\u540e\u7684 multi-expert active path \u662f\u5426\u80fd\u7a33\u5b9a\u8fdb\u5165\u771f\u5b9e\u8bad\u7ec3\u94fe\u8def\uff0c\u5e76\u5728\u4e0d\u8d85\u8fc7\u5f53\u524d\u9884\u7b97\u7684\u524d\u63d0\u4e0b\u7ed9\u51fa\u6bd4\u5355 expert \u8def\u7531\u66f4\u597d\u7684\u91cd\u6784\u3002\u6309\u5f53\u524d\u6210\u672c\u6a21\u578b\u4f30\u7b97\uff0c\u8be5\u70b9\u7ea6\u4e3a encoder 0.54x\u3001deployment 0.19x\u3001total 0.72x\uff0c\u4f4e\u4e8e 1.5\u00d7h\u00d7n \u786c\u7ea6\u675f\u3002",
research/history/memory.json:106:      "pattern": "\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4fdd\u6301\u4e3a x_hat = \u03a3_{e\u2208E(x)} \u03a3_{i\u2208S_e(x)} \u03b1_{e,i}(x) b_{e,i}\uff0c\u5176\u4e2d E(x) \u662f\u8f7b\u91cf router \u9009\u51fa\u7684\u5c11\u91cf active experts\uff0c\u672c\u8f6e\u8bbe |E(x)|=2\uff1b\u6bcf\u4e2a B_e={b_{e,i}} \u90fd\u662f\u9759\u6001 expert \u5b50\u5e93\uff0c\u5728\u7ebf\u4fa7\u53ea\u505a\u201c\u9009 2 \u4e2a\u9759\u6001\u5b50\u5e93 + \u5b50\u5e93\u5185\u67e5\u8868/top-k + \u6709\u9650\u52a0\u6743\u6c42\u548c\u201d\uff0c\u53ef\u76f4\u63a5\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u67e5\u8868\u63a8\u7406\u94fe\u8def\uff0c\u56e0\u6b64 `expert_topk` \u5c5e\u4e8e\u76f4\u63a5\u517c\u5bb9\u3002\u76f8\u5bf9\u5730\uff0c`factorized_expert_topk` \u53ea\u5c5e\u6269\u5c55\u517c\u5bb9\u4e14\u6700\u8fd1\u591a\u8f6e matched probe \u5df2\u7a33\u5b9a\u504f\u5f31\uff1b`batch_topk` / `adaptive_budget_topk` \u5c5e\u4e0d\u517c\u5bb9\uff0c\u4e0d\u80fd\u9a71\u52a8 frontier\u3002\u552f\u4e00\u4e3b\u5047\u8bbe\u662f\uff1ar69\u2192r73\u2192r74 \u5df2\u8bc1\u660e routed-only `expert_topk` \u5728\u56fa\u5b9a `K=160` \u4e0b\u968f `NUM_EXPERTS` \u6269\u5bb9\u4ecd\u6709\u6b63\u6536\u76ca\uff0c\u4f46\u5f53\u524d\u4ecd\u53ea\u6fc0\u6d3b\u5355 expert\uff0c\u5c1a\u672a\u56de\u7b54\u201c\u5bb9\u91cf\u9971\u548c\u70b9\u662f\u5426\u5176\u5b9e\u53d7 active path \u8fc7\u77ed\u9650\u5236\u201d\u3002\u76f8\u5bf9 r74 \u53ea\u5c06 `ACTIVE_EXPERTS: 1 -> 2`\uff0c\u82e5\u5f53\u524d\u74f6\u9888\u662f\u5355 token \u53ea\u80fd\u8bbf\u95ee\u4e00\u4e2a\u5b50\u5e93\uff0c\u90a3\u4e48\u5728\u4fdd\u6301 router \u5f88\u8f7b\u4e14\u603b\u5f62\u5f0f\u4ecd\u4e3a\u9759\u6001\u5b50\u5e93\u6709\u9650\u548c\u7684\u524d\u63d0\u4e0b\uff0cFVU \u5e94\u660e\u663e\u4f4e\u4e8e 0.1243\uff0c\u5e76\u5728\u7ea6 total_cost=0.69x\uff08selection\u22480.53x\uff0cdeployment\u22480.16x\uff09\u7684\u53ef\u884c\u5e26\u5185\u5f62\u6210\u65b0\u7684 MoE-like \u7ed3\u6784\u951a\u70b9\u3002",

import sys
sys.path.insert(0, '.')
import torch
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
for ratio in [0.25, 0.3125, 0.375]:
    cfg = SparseCoderConfig(
        architecture='dual_shared_product_key_expert_jumprelu',
        k=32,
        expansion_factor=1,
        num_experts=2048,
        active_experts=2,
        latents_per_expert=56,
        stage1_ratio=ratio,
    )
    sae = SparseCoder(1024, cfg, device='cpu', dtype=torch.float32)
    x = torch.randn(2, 1024)
    out = sae(x)
    out.fvu.backward()
    print('ratio', ratio, 'stage1_k', sae.stage1_k, 'stage2_k', sae.stage2_k, 'combined_ratio', sae.selection_cost_estimate(4096)['combined_ratio'])

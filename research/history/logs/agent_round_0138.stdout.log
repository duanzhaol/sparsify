        selected_bias = self.expert_head_bias[selected_expert_idx]
        pre_acts = torch.einsum("bh,balh->bal", hidden, selected_weight) + selected_bias
        acts = F.relu(pre_acts) * selected_probs.unsqueeze(-1)

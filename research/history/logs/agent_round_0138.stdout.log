    def encode(self, x: Tensor) -> EncoderOutput:
        x = x - self.b_dec
        original_shape = x.shape[:-1]
        flat_x = x.reshape(-1, self.d_in)

        hidden = F.relu(self.factor_encoder(flat_x))

from research.AutoResearch.target_profile import default_target_profile
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
profile = default_target_profile()
for arch,k,extra in [
    ('lowrank_expert_topk',128,{'num_experts':32,'trunk_rank':36}),
    ('lowrank_expert_topk',128,{'num_experts':32,'trunk_rank':40}),
    ('lowrank_expert_topk',96,{'num_experts':32,'trunk_rank':40}),
    ('lowrank_expert_residual',128,{'num_experts':32,'trunk_rank':40,'stage1_ratio':0.25}),
    ('lowrank_expert_residual',128,{'num_experts':32,'trunk_rank':48,'stage1_ratio':0.25}),
    ('two_stage_residual_expert',128,{'num_experts':32,'stage1_ratio':0.25}),
]:
    cfg = SparseCoderConfig(architecture=arch, k=k, expansion_factor=1, **extra)
    cls = _get_sae_class(arch)
    m = cls(profile.d_in, cfg, device='cpu')
    c = m.selection_cost_estimate(profile.n_output)
    print(arch, k, extra, 'sel', c['ratio'], 'dep', c['deployment_ratio'], 'tot', c['combined_ratio'])

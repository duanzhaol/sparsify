/bin/bash -lc "python - <<'PY'
from research.AutoResearch.target_profile import default_target_profile
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
profile = default_target_profile()
for k in [96,112,128]:
    cfg = SparseCoderConfig(architecture='lowrank_expert_topk', k=k, expansion_factor=1, num_experts=32, trunk_rank=40)
    m = _get_sae_class('lowrank_expert_topk')(profile.d_in, cfg, device='cpu')
    c = m.selection_cost_estimate(profile.n_output)
    print('k', k, 'sel', c['ratio'], 'dep', c['deployment_ratio'], 'tot', c['combined_ratio'])

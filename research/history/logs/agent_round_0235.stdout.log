/bin/bash -lc "python - <<'PY'
import json,glob
# show best objective by family for current target among compatible-ish runs
best={}
for p in sorted(glob.glob('research/history/round_summaries/round_*.json')):
    with open(p) as f:
        s=json.load(f)
    fam=s.get('family_name')
    if not fam:
        continue
    res=s.get('result',{})
    obj=res.get('objective_score')
    if obj in (None,''):
        continue
    try:
        obj=float(obj)
    except:
        continue
    cfg=s.get('runtime_config_json',{})
    hp=cfg.get('hookpoints') or s.get('target_profile',{}).get('training_hookpoint')
    if hp"'!='"'layers.[3].self_attn.q_proj':
        continue
    prev=best.get(fam)
    if prev is None or obj<prev[0]:
        best[fam]=(obj,s['round'],res.get('total_cost_ratio'),res.get('exceed_alpha_0_50'),cfg.get('k'))
for fam in sorted(best, key=lambda x: best[x][0]):
    print(fam, best[fam])

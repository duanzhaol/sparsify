            "event_id": event_id,
            "ts": int(time.time()),
            "event": event,
            **payload,
        }
        timeline_path = self.history_dir / "timeline.jsonl"
        with open(timeline_path, "a") as f:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
        return event_id


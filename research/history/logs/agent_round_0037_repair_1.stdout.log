+            ("residual_encoder", self.residual_encoder),
+        ]
+
+    def _extra_encode_accesses(self) -> list[tuple[str, int, str]]:
+        return [
+            (
+                "active_expert_encoder",
+                self.d_in * self.latents_per_expert,
+                f"active=1×{self.d_in}x{self.latents_per_expert}",

import sys
sys.path.insert(0,'.')
import torch
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig

device = 'cuda' if torch.cuda.is_available() else 'cpu'
try:
    import torch_npu
    if torch.npu.is_available():
        device = 'npu'
except ImportError:
    pass

arch = 'residual_dual_shared_product_key_expert_jumprelu'
k = 32
ef = 1
cfg = SparseCoderConfig(
    architecture=arch,
    k=k,
    expansion_factor=ef,
    num_experts=1024,
    active_experts=2,
    latents_per_expert=56,
    stage1_ratio=0.375,
    factorized_hidden_dim=256,
    trunk_rank=16,
)
sae = SparseCoder(1024, cfg, device=device, dtype=torch.float32)
x = torch.randn(4, 1024, device=device)
out = sae(x)
out.fvu.backward()
print('integration_smoke: OK', arch, k, ef, device)
print('cost', sae.selection_cost_estimate(n_output=4096))

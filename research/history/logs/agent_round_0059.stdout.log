STRUCTURAL_OVERRIDE_KEYS = {
    "ARCHITECTURE",
    "K",
    "EXPANSION_FACTOR",
    "NUM_GROUPS",
    "ACTIVE_GROUPS",
    "MATRYOSHKA_KS",

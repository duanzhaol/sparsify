        self.stage1b_k = self.stage1_k - self.stage1a_k

    def _encode_single_shared_bank(
        self,
        x_centered: Tensor,
        *,
        bank_idx: int,
        topk: int,
        index_offset: int,
    ) -> tuple[Tensor, Tensor, Tensor]:

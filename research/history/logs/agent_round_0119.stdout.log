/bin/bash -lc "python - <<'PY'
import sys, json
sys.path.insert(0,'.')
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
families=['two_stage_residual_expert','lowrank_expert_topk','lowrank_expert_residual']
for fam in families:
    try:
        cls=_get_sae_class(fam)
        cfg=SparseCoderConfig(architecture=fam,k=96,expansion_factor=1,num_experts=32,trunk_rank=40,stage1_ratio=0.25)
        m=cls(1024,cfg,device='cpu')
        est=getattr(m,'selection_cost_estimate',None)
        if est:
            print(fam, json.dumps(m.selection_cost_estimate(4096), sort_keys=True))
        else:
            print(fam, 'NO_EST')
    except Exception as e:
        print(fam, 'ERR', repr(e))

import json, os, glob
rows=[]
for path in sorted(glob.glob('research/history/round_summaries/round_*.json')):
    with open(path) as f:
        d=json.load(f)
    r=d.get('round')
    if r is None or r < 170:
        continue
    res=d.get('result', {})
    arch=res.get('architecture')
    obj=res.get('objective_score')
    cost=res.get('total_cost_ratio')
    exc=res.get('exceed_alpha_0_50')
    if arch and obj is not None:
        rows.append((r, arch, float(obj), float(cost), float(exc)))
for r, arch, obj, cost, exc in rows:
    print(f'{r:4d} {arch:38s} obj={obj:.6f} cost={cost:.6f} exceed={exc:.6f}')

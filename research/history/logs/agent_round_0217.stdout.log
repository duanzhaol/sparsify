import torch
from sparsify.config import SparseCoderConfig
from sparsify import SparseCoder
archs = [
    'expert_topk',
    'lowrank_expert_topk',
    'shared_routed_expert_topk',
    'shared_two_stage_residual_expert',
    'shared_lowrank_routed_expert_topk',
    'shared_routed_factorized_expert_topk',
    'shared_lowrank_two_stage_residual_expert',
]
base = dict(k=32, expansion_factor=1, architecture='expert_topk', trunk_rank=16, factorized_hidden_dim=256, num_experts=128, active_experts=2, latents_per_expert=192, stage1_ratio=0.25)
for arch in archs:
    cfg = SparseCoderConfig(**{**base, 'architecture': arch})
    sae = SparseCoder(1024, cfg, device='cpu', dtype=torch.float32)
    est = sae.selection_cost_estimate(n_output=4096)
    print(arch, est['ratio'], est['deployment_ratio'], est['combined_ratio'], est['combined_feasible'])

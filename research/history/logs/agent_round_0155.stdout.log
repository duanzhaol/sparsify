device='cpu'
arch='shared_lowrank_routed_expert_topk'
cfg=SparseCoderConfig(
    architecture=arch,
    k=96,
    expansion_factor=1,
    factorized_hidden_dim=256,
    num_experts=64,
    active_experts=2,
    latents_per_expert=224,
    stage1_ratio=0.25,
    trunk_rank=16,
)
sae=SparseCoder(1024, cfg, device=device, dtype=torch.float32)
x=torch.randn(4,1024,device=device)
out=sae(x)
out.fvu.backward()
print('integration_smoke: OK', arch, cfg.k, cfg.expansion_factor, device, 'fvu=', float(out.fvu))
print('cost=', sae.selection_cost_estimate(4096))

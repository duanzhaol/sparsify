sys.path.insert(0,'.')
from sparsify.sparse_coder import _get_sae_class
from sparsify.config import SparseCoderConfig
cases=[
('shared_lowrank_routed_expert_topk', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('shared_lowrank_two_stage_residual_expert', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('shared_lowrank_routed_expert_residual', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('shared_routed_factorized_expert_topk', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('shared_routed_factorized_expert_residual', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('lowrank_expert_topk', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('two_stage_residual_expert', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
('lowrank_expert_residual', dict(k=96, expansion_factor=1, factorized_hidden_dim=256, num_experts=64, active_experts=2, latents_per_expert=224, stage1_ratio=0.25, trunk_rank=16)),
]
for arch, kw in cases:
    try:
        cfg=SparseCoderConfig(architecture=arch, **kw)
        cls=_get_sae_class(arch)
        m=cls(1024,cfg,device='cpu')
        cost=m.selection_cost_estimate(4096)
        print(arch, json.dumps(cost))
    except Exception as e:
        print(arch, 'ERROR', repr(e))

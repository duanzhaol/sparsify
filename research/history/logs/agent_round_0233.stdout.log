cands=[('lowrank_residual',1,64,{}),('lowrank_grouped_residual',1,64,{}),('lowrank_jumprelu_residual',1,64,{'jumprelu_bandwidth':0.05,'jumprelu_init_threshold':0.02}),('lowrank_factorized_residual',1,64,{'factorized_hidden_dim':96}),('lowrank_soft_codebook_residual',1,64,{}),('lowrank_gated_residual',1,64,{}),('lowrank_gated_soft_codebook_residual',1,64,{}),('lowrank_grouped_soft_codebook_residual',1,64,{})]

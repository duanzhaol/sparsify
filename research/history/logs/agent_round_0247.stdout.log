import sys
sys.path.insert(0,'.')
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import SparseCoder

def cost_ratio(**kwargs):
    cfg = SparseCoderConfig(
        architecture='product_key_expert_jumprelu',
        k=kwargs.get('k',32),
        expansion_factor=1,
        num_experts=kwargs.get('num_experts',512),
        active_experts=kwargs.get('active_experts',2),
        latents_per_expert=kwargs.get('latents_per_expert',192),
        factorized_hidden_dim=256,
    )
    sae = SparseCoder(1024, cfg, device='cpu', dtype=None)
    total = sae.compute_total_cost(1024, 4096)
    print(kwargs, float(total / (1024*4096)))

for kw in [
    {'num_experts':512,'latents_per_expert':160},
    {'num_experts':512,'latents_per_expert':224},
    {'num_experts':512,'k':48},
    {'num_experts':1024,'latents_per_expert':192},
    {'num_experts':512,'active_experts':1},
]:
    cost_ratio(**kw)

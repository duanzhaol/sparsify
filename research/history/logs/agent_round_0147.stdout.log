import sys
sys.path.insert(0,'.')
from sparsify.config import SparseCoderConfig
from sparsify.sparse_coder import _get_sae_class
for arch, kwargs in [
    ('two_stage_residual_expert', dict(k=112, expansion_factor=1, stage1_ratio=0.25, num_experts=64, active_experts=2, latents_per_expert=224)),
]:
    try:
        cfg = SparseCoderConfig(architecture=arch, **kwargs)
        cls = _get_sae_class(arch)
        m = cls(1024, cfg, device='cpu')
        x = __import__('torch').randn(2,1024)
        out = m(x)
        print(arch, 'OK', tuple(out.sae_out.shape), float(out.fvu))
    except Exception as e:
        print(arch, 'ERR', type(e).__name__, e)

import sys
sys.path.insert(0,'.')
from sparsify import SparseCoder
from sparsify.config import SparseCoderConfig
for k in [64,80,96]:
  for r in [8,12,16]:
    cfg = SparseCoderConfig(architecture='lowrank_residual', expansion_factor=1, k=k, trunk_rank=r)
    sae = SparseCoder(1024, cfg, device='cpu', dtype=None)
    c = sae.selection_cost_estimate(4096)
    print('lowrank_residual', 'k', k, 'r', r, 'combined', c['combined_ratio'], 'sel', c['ratio'], 'dep', c['deployment_ratio'])
PY" in /root/sparsify-ascend

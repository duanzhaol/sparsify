research/history/round_summaries/round_0203.json:19:    "hypothesis": "\u5019\u9009 probe family \u7684\u6700\u7ec8\u91cd\u6784\u516c\u5f0f\u4e3a x_hat = U(Vx) + \u03a3_m pi_m c_m + \u03a3_i alpha_i^(1) b_i + \u03a3_j alpha_j^(2) b_j\uff0c\u5176\u4e2d\u4ec5\u5c06\u4e24\u9636\u6bb5 residual refinement \u7684\u9884\u7b97\u5206\u914d\u6539\u4e3a\u524d\u91cd\u540e\u8f7b\uff0c\u8fd1\u4f3c stage1_k\u22480.75K\u3001stage2_k\u22480.25K\u3002low-rank trunk \u9879 U(Vx) \u53ef\u5bfc\u51fa\u4e3a\u9759\u6001 trunk \u5411\u91cf\u5e93\u4e0a\u7684\u52a0\u6743\u548c\uff0csoft codebook \u9879 \u03a3_m pi_m c_m \u53ef\u5bfc\u51fa\u4e3a\u9759\u6001 codebook \u5e93\u4e0a\u7684\u52a0\u6743\u548c\uff0c\u4e24\u9636\u6bb5 residual \u9879\u4ecd\u53ef\u5bfc\u51fa\u4e3a\u9759\u6001 residual \u5b57\u5178\u4e0a\u7684\u6709\u9650\u7a00\u758f\u52a0\u6743\u548c\uff0c\u56e0\u6b64\u53ef\u76f4\u63a5\u6620\u5c04\u5230 LUTurbo/Lottable \u7684\u201c\u67e5\u8868 + \u52a0\u6743\u6c42\u548c + \u9009\u62e9\u6027\u8865\u507f\u201d\u63a8\u7406\u94fe\u8def\u3002\u517c\u5bb9\u6027\u5224\u65ad\u4e3a\u6269\u5c55\u517c\u5bb9\u3002\u4e3b\u5047\u8bbe\uff1a\u5728\u4fdd\u6301 K=128\u3001EXPANSION_FACTOR=2\u3001OPTIMIZER=signum\u3001LR=3.0e-3 \u5b8c\u5168 matched \u7684\u524d\u63d0\u4e0b\uff0c\u56fa\u5b9a\u524d\u7f6e\u66f4\u591a stage1 \u9884\u7b97\u662f\u5426\u80fd\u6bd4\u5bf9\u79f0 two-stage \u66f4\u597d\u5730\u5229\u7528\u6709\u9650 K\uff0c\u4ece\u800c\u5224\u65ad asymmetric two-stage \u8fd9\u6761 family \u5728\u4f4e EF \u53ef\u90e8\u7f72 regime \u4e0b\u662f\u5426\u503c\u5f97\u7ee7\u7eed\u3002",
research/history/round_summaries/round_0203.json:20:    "summary": "\u6267\u884c\u4e00\u4e2a\u5408\u6cd5\u7684 matched architecture probe\uff1afamily_name \u5207\u5230 lowrank_asymmetric_two_stage_soft_codebook_residual\uff0c\u5176\u4f59 recipe \u4fdd\u6301 K=128\u3001EXPANSION_FACTOR=2\u3001OPTIMIZER=signum\u3001LR=3.0e-3 \u4e0d\u53d8\u3002\u8be5 family \u7684\u6700\u7ec8\u91cd\u6784\u4ecd\u53ef\u5bfc\u51fa\u5230 LUTurbo/Lottable \u7684\u9759\u6001\u67e5\u8868\u94fe\u8def\uff0c\u517c\u5bb9\u6027\u4e3a\u6269\u5c55\u517c\u5bb9\uff1b\u672c\u8f6e\u53ea\u56de\u7b54\u4e00\u4e2a\u95ee\u9898\uff0c\u5373\u56fa\u5b9a\u524d\u7f6e\u66f4\u591a stage1 \u7a00\u758f\u9884\u7b97\u7684 asymmetric two-stage \u7ed3\u6784\u5728\u5f53\u524d\u4f4e EF regime \u4e0b\u662f\u5426\u503c\u5f97\u7ee7\u7eed\u3002",
research/history/round_summaries/round_0203.json:23:    "family_name": "lowrank_asymmetric_two_stage_soft_codebook_residual",
research/history/round_summaries/round_0203.json:24:    "family_stage": "matched_probe",
research/history/round_summaries/round_0203.json:25:    "self_review": "\u8fd9\u6b21\u6cbf\u7528 r202 \u5df2\u9a8c\u8bc1\u901a\u8fc7\u7684 architecture action \u5f62\u72b6\uff1aarchitecture \u53ea\u7531 family_name \u6307\u5b9a\uff0c\u4e0d\u5728 env_overrides \u4e2d\u91cd\u590d\u58f0\u660e\u3002\u76f8\u6bd4\u7ee7\u7eed\u91cd\u590d\u5df2\u5f97\u5230\u6709\u6548\u7ed3\u679c\u7684 lowrank_soft_codebook_residual \u6216 lowrank_residual\uff0c\u8fd9\u4e2a asymmetric two-stage \u53d8\u4f53\u662f\u5f53\u524d\u6700\u6709\u4fe1\u606f\u4ef7\u503c\u4e14\u5c1a\u672a\u83b7\u5f97\u6709\u6548 matched \u8fd0\u884c\u7684\u53ef\u884c family\u3002",

research/history/round_summaries/round_0121.json:20:    "summary": "\u5728\u9884\u7b97\u5185\u4e3b\u7ebf family \u4e0a\u505a\u4e00\u6b21\u7eaf LR \u6e05\u6d17\uff1a\u56fa\u5b9a lowrank_two_stage_soft_codebook_residual\u3001K=128\u3001EF=2\u3001signum\uff0c\u4ec5\u628a LR \u4ece 3.0e-3 \u4e0b\u8c03\u5230 2.4e-3\uff0c\u9a8c\u8bc1\u662f\u5426\u80fd\u4ee5\u76f8\u540c selection_cost/deploy_cost \u6362\u53d6\u66f4\u4f4e FVU\u3002",
research/history/round_summaries/round_0121.json:23:    "family_name": "lowrank_two_stage_soft_codebook_residual",

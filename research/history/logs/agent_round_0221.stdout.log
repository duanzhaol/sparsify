research/history/round_summaries/round_0135.json:79:    "self_review": "\u9075\u5b88\u672c\u8f6e\u67b6\u6784\u63a2\u9488\u7ea6\u675f\uff0c\u6ca1\u6709\u8054\u52a8\u6539 recipe\u3002\u9009\u62e9 lowrank_residual \u800c\u975e\u7ee7\u7eed\u91cd\u590d\u88ab\u62d2\u7684 lowrank_soft_codebook_residual probe\uff0c\u53ef\u4ee5\u66f4\u76f4\u63a5\u6d4b\u8bd5 soft codebook \u5206\u652f\u672c\u8eab\u7684\u5fc5\u8981\u6027\uff1b\u98ce\u9669\u662f\u8be5 family \u53ef\u80fd\u5728 K=128 \u4e0b FVU \u660e\u663e\u504f\u5f31\uff0c\u4f46\u8fd9\u6b63\u662f\u63a2\u9488\u9700\u8981\u786e\u8ba4\u7684\u4fe1\u53f7\u3002",

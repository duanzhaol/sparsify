research/history/round_summaries/round_0072.json:7:  "family_name": "two_stage_residual",
research/history/round_summaries/round_0072.json:8:  "family_stage": "mainline",
research/history/round_summaries/round_0072.json:17:    "hypothesis": "Round 71 gave a clean positive answer on the learning-rate axis for `two_stage_residual`: `LR=2.4e-3` improved the start (`0.173863` vs `0.176606`), mid-curve (`0.133819` vs `0.134559`), and endpoint (`0.127782` vs `0.127844`) relative to the archived `2.0e-3` baseline, so the signum LR question is now sufficiently clarified. The next single mainline question, in the prescribed order, is optimizer: with the stronger `two_stage_residual` recipe now anchored at `LR=2.4e-3`, does switching from `signum` to `adam` produce a healthier full training curve or competitive final FVU, or does this family still clearly prefer `signum`?",
research/history/round_summaries/round_0072.json:21:    "family_name": "two_stage_residual",
research/history/round_summaries/round_0072.json:22:    "family_stage": "mainline",
research/history/round_summaries/round_0072.json:23:    "self_review": "This stays on the active mainline family, respects the fixed `EXPANSION_FACTOR=12` rule, uses an allowed `K`, and changes exactly one primary variable: `optimizer`. It follows the required sequence after completing the initial within-family LR sweep, and it uses the strongest observed signum anchor rather than reopening K, loss, or preprocess prematurely. The main risk is that `adam` may underperform badly, but that is exactly the branch this round is meant to settle before any optimizer-specific LR callback.",
research/history/round_summaries/round_0155.json:7:  "family_name": "lowrank_two_stage_soft_codebook_residual",

research/history/round_summaries/round_0008.json:20:    "summary": "\u7ee7\u7eed\u56f4\u7ed5 topk \u4e3b\u7ebf\u63a8\u8fdb\uff0c\u4e0d\u5f00\u65b0 family\uff0c\u4e0d\u52a8 K\u3002\u672c\u8f6e\u6309\u63a8\u8350\u987a\u5e8f\u4ece\u5b66\u4e60\u7387\u626b\u63cf\u5207\u5230\u4f18\u5316\u5668\u6bd4\u8f83\uff1b\u552f\u4e00\u4e3b\u53d8\u91cf\u662f OPTIMIZER\uff1a\u4ece signum \u6539\u4e3a adam\uff0c\u540c\u65f6\u4fdd\u6301 ARCHITECTURE=topk\u3001K=128\u3001EXPANSION_FACTOR=12\u3001LR=1.6e-3 \u4e0d\u53d8\u3002",

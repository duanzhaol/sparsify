research/history/round_summaries/round_0194.json:25:    "self_review": "\u8fd9\u662f\u4e00\u4e2a\u4e25\u683c\u5355\u53d8\u91cf\u7684 matched probe\uff0c\u79d1\u5b66\u95ee\u9898\u5355\u4e00\u660e\u786e\uff1a\u9a8c\u8bc1 factorized scorer \u8fd9\u7c7b\u4f4e\u6210\u672c\u9009\u62e9\u673a\u5236\u5728\u517c\u5bb9 residual family \u4e2d\u662f\u5426\u503c\u5f97\u7ee7\u7eed\u3002\u867d\u7136\u5176\u73b0\u6709 frontier \u70b9\u8f83\u5f31\uff0c\u4f46\u5b83\u80fd\u76f4\u63a5\u56de\u7b54\u2018\u66f4\u4fbf\u5b9c\u7684 selector \u662f\u5426\u8fd8\u80fd\u4fdd\u4f4f\u53ef\u7528 FVU\u2019\u8fd9\u4e00\u90e8\u7f72\u76f8\u5173\u95ee\u9898\uff0c\u4fe1\u606f\u4ef7\u503c\u9ad8\u4e8e\u91cd\u590d\u5df2\u5931\u8d25\u7684 soft-codebook siblings\u3002",
research/history/round_summaries/round_0194.json:74:    "description": "\u6267\u884c\u4e00\u4e2a matched architecture probe\uff1a\u5c06\u4e3b\u7ebf\u5207\u5230 lowrank_factorized_residual\uff0c\u5176\u4f59 recipe \u4fdd\u6301 K=128\u3001EXPANSION_FACTOR=2\u3001OPTIMIZER=signum\u3001LR=3.0e-3 \u4e0d\u53d8\u3002\u8be5\u67b6\u6784\u7684\u6700\u7ec8\u91cd\u6784\u4ecd\u662f trunk \u9759\u6001\u5e93\u4e0e residual \u9759\u6001\u5b57\u5178\u4e0a\u7684\u6709\u9650\u52a0\u6743\u548c\uff0c\u5c5e\u6269\u5c55\u517c\u5bb9\uff1b\u672c\u8f6e\u53ea\u56de\u7b54\u4e00\u4e2a\u95ee\u9898\uff0c\u5373 factorized scorer \u5e26\u6765\u7684\u66f4\u4f4e encoder \u6210\u672c\u662f\u5426\u8db3\u4ee5\u8ba9\u8be5 family \u7ee7\u7eed\u4f5c\u4e3a LUTurbo \u4f4e\u6210\u672c\u5019\u9009\u3002",
research/history/round_summaries/round_0194.json:75:    "self_review": "\u8fd9\u662f\u4e00\u4e2a\u4e25\u683c\u5355\u53d8\u91cf\u7684 matched probe\uff0c\u79d1\u5b66\u95ee\u9898\u5355\u4e00\u660e\u786e\uff1a\u9a8c\u8bc1 factorized scorer \u8fd9\u7c7b\u4f4e\u6210\u672c\u9009\u62e9\u673a\u5236\u5728\u517c\u5bb9 residual family \u4e2d\u662f\u5426\u503c\u5f97\u7ee7\u7eed\u3002\u867d\u7136\u5176\u73b0\u6709 frontier \u70b9\u8f83\u5f31\uff0c\u4f46\u5b83\u80fd\u76f4\u63a5\u56de\u7b54\u2018\u66f4\u4fbf\u5b9c\u7684 selector \u662f\u5426\u8fd8\u80fd\u4fdd\u4f4f\u53ef\u7528 FVU\u2019\u8fd9\u4e00\u90e8\u7f72\u76f8\u5173\u95ee\u9898\uff0c\u4fe1\u606f\u4ef7\u503c\u9ad8\u4e8e\u91cd\u590d\u5df2\u5931\u8d25\u7684 soft-codebook siblings\u3002",

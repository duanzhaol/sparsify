{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_summary",
    "keep_rounds",
    "drop_rounds",
    "round_decisions",
    "keep_log_artifacts",
    "drop_log_artifacts",
    "timeline_policy",
    "memory_focus",
    "session_brief_focus",
    "safety_checks"
  ],
  "properties": {
    "strategy_summary": {
      "type": "string"
    },
    "keep_rounds": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "drop_rounds": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "round_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "round",
          "decision",
          "reason",
          "compressed_summary",
          "retain_artifacts"
        ],
        "properties": {
          "round": {
            "type": "integer"
          },
          "decision": {
            "type": "string",
            "enum": ["keep", "drop"]
          },
          "reason": {
            "type": "string"
          },
          "compressed_summary": {
            "type": "string"
          },
          "retain_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "keep_log_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "drop_log_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timeline_policy": {
      "type": "string",
      "enum": ["full", "filtered", "rebuild_digest"]
    },
    "memory_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve_family_names",
        "preserve_failure_modes",
        "preserve_code_lineage",
        "extra_takeaways"
      ],
      "properties": {
        "preserve_family_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserve_failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserve_code_lineage": {
          "type": "boolean"
        },
        "extra_takeaways": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "session_brief_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recent_rounds",
        "next_move_guidance"
      ],
      "properties": {
        "recent_rounds": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "next_move_guidance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "results_tsv_full",
        "frontier_exact",
        "pareto_exact",
        "best_family_preserved",
        "code_lineage_preserved",
        "blocked_failures_preserved"
      ],
      "properties": {
        "results_tsv_full": {
          "type": "boolean"
        },
        "frontier_exact": {
          "type": "boolean"
        },
        "pareto_exact": {
          "type": "boolean"
        },
        "best_family_preserved": {
          "type": "boolean"
        },
        "code_lineage_preserved": {
          "type": "boolean"
        },
        "blocked_failures_preserved": {
          "type": "boolean"
        }
      }
    }
  }
}
